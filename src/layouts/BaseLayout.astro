---
import ViewTransitions from 'astro/components/ViewTransitions.astro';

export interface Props {
  title: string;
  description?: string;
  lang?: "zh" | "en";
  image?: string;
  activeNav?: string;
}
const {
  title,
  description = "BTC & ETH 价格行为分析、链上数据、衍生品分析。中英双语。",
  lang = "zh",
  image = "/og-default.png",
  activeNav = "",
} = Astro.props;

const zhPath = Astro.url.pathname.replace(/^\/en\//, "/zh/");
const enPath = Astro.url.pathname.replace(/^\/zh\//, "/en/");
---

<!doctype html>
<html lang={lang === "zh" ? "zh-CN" : "en-US"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#020617" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="1H Crypto Trader" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title + " - 1H币研"} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="1H币研 | 1H Crypto" />
    <meta property="og:locale" content={lang === "zh" ? "zh_CN" : "en_US"} />
    <meta property="og:locale:alternate" content={lang === "zh" ? "en_US" : "zh_CN"} />

    <!-- ViewTransitions: SPA 无刷新导航 -->
    <ViewTransitions />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content={title + " - 1H币研"} />

    <!-- Canonical + hreflang -->
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" hreflang={lang === "zh" ? "zh-CN" : "en-US"} href={Astro.url.href} />
    <link rel="alternate" hreflang={lang === "zh" ? "en-US" : "zh-CN"} href={lang === "zh" ? Astro.url.pathname.replace(/^\/zh\//, "/en/") : Astro.url.pathname.replace(/^\/en\//, "/zh/")} />
    <link rel="alternate" hreflang="x-default" href="https://1hcrypto.com/zh/" />

    <!-- Robots -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Schema.org - Organization + WebSite -->
    <script type="application/ld+json" set:html={`{
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "1H币研",
          "alternateName": "1H Crypto",
          "url": "https://1hcrypto.com",
          "description": "${description}",
          "inLanguage": "${lang === "zh" ? "zh-CN" : "en-US"}",
          "sameAs": [
            "https://twitter.com/1hcrypto",
            "https://t.me/1hcrypto"
          ]
        },
        {
          "@type": "WebSite",
          "name": "1H币研 | 1H Crypto",
          "url": "https://1hcrypto.com",
          "description": "${description}",
          "inLanguage": "${lang === "zh" ? "zh-CN" : "en-US"}",
          "potentialAction": {
            "@type": "SearchAction",
            "target": "https://1hcrypto.com/${lang === "zh" ? "zh" : "en"}/search?q={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        }
      ]
    }`}></script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>

    <!-- Global CSS -->
    <link rel="stylesheet" href="/global.css" />
  </head>

  <body class="min-h-screen flex flex-col bg-[var(--bg-primary)] text-[var(--text-primary)]">
    <!-- 滚动进度条 -->
    <div id="scroll-progress" class="scroll-progress-bar"></div>

    <!-- 鼠标跟随光晕（仅桌面端） -->
    <div id="cursor-glow" class="cursor-glow hidden md:block"></div>

    <!-- 背景浮动粒子 -->
    <div class="bg-particles hidden md:block">
      <div class="particle"></div><div class="particle"></div><div class="particle"></div>
      <div class="particle"></div><div class="particle"></div><div class="particle"></div>
      <div class="particle"></div><div class="particle"></div><div class="particle"></div>
      <div class="particle"></div><div class="particle"></div><div class="particle"></div>
      <div class="particle"></div><div class="particle"></div><div class="particle"></div>
    </div>

    <!-- Navigation -->
    <nav class="nav-glass sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">

          <!-- Logo -->
          <a href={lang === "zh" ? "/zh/" : "/en/"} class="flex items-center gap-2 hover:opacity-80 transition-opacity no-underline shrink-0">
            <span class="text-lg font-bold tracking-tight gradient-text">1H币研</span>
          </a>

          <!-- Desktop Nav Links -->
          <div class="hidden md:flex items-center gap-0.5 text-[13px]">
            <!-- 核心导航 -->
            <a
              href={lang === "zh" ? "/zh/" : "/en/"}
              class:list={["relative no-underline transition-colors px-3 py-2 rounded-md", activeNav === "home" ? "text-primary font-semibold" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}
            >
              {lang === "zh" ? "首页" : "Home"}
              {activeNav === "home" && <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-0.5 bg-primary rounded-full"></span>}
            </a>
            <a
              href={lang === "zh" ? "/zh/daily/" : "/en/daily/"}
              class:list={["relative no-underline transition-colors px-3 py-2 rounded-md", activeNav === "daily" ? "text-primary font-semibold" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}
            >
              {lang === "zh" ? "每日研判" : "Daily Analysis"}
              {activeNav === "daily" && <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-0.5 bg-primary rounded-full"></span>}
            </a>
            <a
              href={lang === "zh" ? "/zh/analysis/" : "/en/analysis/"}
              class:list={["relative no-underline transition-colors px-3 py-2 rounded-md", activeNav === "analysis" ? "text-primary font-semibold" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}
            >
              {lang === "zh" ? "价格分析" : "Analysis"}
              {activeNav === "analysis" && <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-0.5 bg-primary rounded-full"></span>}
            </a>
            <a
              href={lang === "zh" ? "/zh/trading/" : "/en/trading/"}
              class:list={["relative no-underline transition-colors px-3 py-2 rounded-md", activeNav === "trading" ? "text-primary font-semibold" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}
            >
              {lang === "zh" ? "模拟盘" : "Paper Trading"}
              {activeNav === "trading" && <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-0.5 bg-primary rounded-full"></span>}
            </a>
            <a
              href={lang === "zh" ? "/zh/tools/" : "/en/tools/"}
              class:list={["relative no-underline transition-colors px-3 py-2 rounded-md", activeNav === "tools" ? "text-primary font-semibold" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}
            >
              {lang === "zh" ? "推荐注册" : "Recommended"}
              {activeNav === "tools" && <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-0.5 bg-primary rounded-full"></span>}
            </a>

            <!-- 分隔线 -->
            <div class="w-px h-4 bg-[var(--border)] mx-1"></div>

            <!-- 更多下拉 -->
            <div class="relative group">
              <button class="flex items-center gap-1 px-3 py-2 rounded-md text-[var(--text-muted)] hover:text-white hover:bg-white/5 transition-colors cursor-pointer">
                {lang === "zh" ? "更多" : "More"}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div class="absolute top-full right-0 mt-1 w-40 py-1.5 bg-[var(--bg-card)] border border-[var(--border)] rounded-xl shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
                <a href={lang === "zh" ? "/zh/news/" : "/en/news/"} class:list={["block px-4 py-2 text-[13px] no-underline transition-colors", activeNav === "news" ? "text-primary font-semibold" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>{lang === "zh" ? "新闻快报" : "News"}</a>
                <a href={lang === "zh" ? "/zh/derivatives/" : "/en/derivatives/"} class:list={["block px-4 py-2 text-[13px] no-underline transition-colors", activeNav === "derivatives" ? "text-primary font-semibold" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>{lang === "zh" ? "衍生品" : "Derivatives"}</a>
                <a href={lang === "zh" ? "/zh/weekly/" : "/en/weekly/"} class:list={["block px-4 py-2 text-[13px] no-underline transition-colors", activeNav === "weekly" ? "text-primary font-semibold" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>{lang === "zh" ? "周度复盘" : "Weekly"}</a>
                <div class="border-t border-[var(--border)] my-1"></div>
                <a href={lang === "zh" ? "/zh/learn/" : "/en/learn/"} class:list={["block px-4 py-2 text-[13px] no-underline transition-colors", activeNav === "learn" ? "text-primary font-semibold" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>{lang === "zh" ? "学习中心" : "Learn"}</a>
                <a href={lang === "zh" ? "/zh/about/" : "/en/about/"} class:list={["block px-4 py-2 text-[13px] no-underline transition-colors", activeNav === "about" ? "text-primary font-semibold" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>{lang === "zh" ? "关于" : "About"}</a>
              </div>
            </div>

            <!-- 分隔线 -->
            <div class="w-px h-4 bg-[var(--border)] mx-1"></div>

            <!-- Lang Switcher -->
            <a
              href={lang === "zh" ? enPath : zhPath}
              class="px-2.5 py-1 text-[11px] rounded-md border border-[var(--border)] hover:border-primary/50 text-[var(--text-muted)] hover:text-white transition-colors no-underline font-medium"
            >
              {lang === "zh" ? "EN" : "中"}
            </a>

            <!-- Theme Toggle -->
            <button
              id="theme-toggle-btn"
              class="w-7 h-7 rounded-md border border-[var(--border)] hover:border-primary/50 flex items-center justify-center text-xs text-[var(--text-muted)] hover:text-white hover:bg-white/5 transition-colors cursor-pointer"
              aria-label="Toggle theme"
            >
              <span id="theme-icon">☀️</span>
            </button>
          </div>

          <!-- Mobile Menu Button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden p-2 text-[var(--text-muted)] hover:text-white transition-colors"
            aria-label="Toggle menu"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <!-- Mobile Nav Panel -->
        <div id="mobile-menu" class="mobile-nav-panel hidden">
          <a href={lang === "zh" ? "/zh/" : "/en/"} class:list={["block py-2.5 no-underline rounded-lg px-3", activeNav === "home" ? "nav-active" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>首页</a>
          <a href={lang === "zh" ? "/zh/daily/" : "/en/daily/"} class:list={["block py-2.5 no-underline rounded-lg px-3", activeNav === "daily" ? "nav-active" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>{lang === "zh" ? "每日研判" : "Daily Analysis"}</a>
          <a href={lang === "zh" ? "/zh/analysis/" : "/en/analysis/"} class:list={["block py-2.5 no-underline rounded-lg px-3", activeNav === "analysis" ? "nav-active" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>{lang === "zh" ? "价格分析" : "Price Analysis"}</a>
          <a href={lang === "zh" ? "/zh/trading/" : "/en/trading/"} class:list={["block py-2.5 no-underline rounded-lg px-3", activeNav === "trading" ? "nav-active" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>{lang === "zh" ? "模拟盘" : "Paper Trading"}</a>
          <a href={lang === "zh" ? "/zh/tools/" : "/en/tools/"} class:list={["block py-2.5 no-underline rounded-lg px-3", activeNav === "tools" ? "nav-active" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>{lang === "zh" ? "推荐注册" : "Recommended"}</a>
          <div class="border-t border-[var(--border)] my-1"></div>
          <a href={lang === "zh" ? "/zh/news/" : "/en/news/"} class:list={["block py-2.5 no-underline rounded-lg px-3", activeNav === "news" ? "nav-active" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>{lang === "zh" ? "新闻快报" : "News"}</a>
          <a href={lang === "zh" ? "/zh/derivatives/" : "/en/derivatives/"} class:list={["block py-2.5 no-underline rounded-lg px-3", activeNav === "derivatives" ? "nav-active" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>{lang === "zh" ? "衍生品" : "Derivatives"}</a>
          <a href={lang === "zh" ? "/zh/weekly/" : "/en/weekly/"} class:list={["block py-2.5 no-underline rounded-lg px-3", activeNav === "weekly" ? "nav-active" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>{lang === "zh" ? "周度复盘" : "Weekly"}</a>
          <a href={lang === "zh" ? "/zh/learn/" : "/en/learn/"} class:list={["block py-2.5 no-underline rounded-lg px-3", activeNav === "learn" ? "nav-active" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>{lang === "zh" ? "学习中心" : "Learn"}</a>
          <a href={lang === "zh" ? "/zh/about/" : "/en/about/"} class:list={["block py-2.5 no-underline rounded-lg px-3", activeNav === "about" ? "nav-active" : "text-[var(--text-muted)] hover:text-white hover:bg-white/5"]}>{lang === "zh" ? "关于" : "About"}</a>
          <div class="pt-3 mt-2 border-t border-[var(--border)] flex gap-3">
            <a href={lang === "zh" ? enPath : zhPath} class="text-sm text-[var(--text-muted)] hover:text-white no-underline px-3 py-1.5 rounded-full border border-[var(--border)]">
              {lang === "zh" ? "English →" : "中文 →"}
            </a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content + Sidebar (sidebar hidden by default) -->
    <main class="flex-1">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 flex flex-col md:flex-row gap-4">
        <!-- Content Area -->
        <div class="flex-1 min-w-0">
          <div class="max-w-4xl">
            <slot />
          </div>

          <!-- 腰部广告位（内容流中间，各页面可选） -->
          <div class="max-w-4xl mt-12 mb-8">
            <slot name="mid-ad" />
          </div>
        </div>

        <!-- Sidebar Ad Slot (hidden by default, enable when ads are ready) -->
        <aside class="hidden w-60 shrink-0 ml-20 self-start sticky top-20">
          <div class="space-y-4">
            <!-- Ad Card 1: Binance -->
            <div class="card overflow-hidden">
              <div class="p-4 bg-[#0f1419] border border-white/5 rounded-xl">
                <div class="flex items-center gap-2 mb-3">
                  <div class="w-8 h-8 rounded-lg bg-[#F0B90B] flex items-center justify-center text-black font-bold text-xs">B</div>
                  <div>
                    <div class="text-white font-semibold text-xs">Binance 币安</div>
                    <div class="text-[10px] text-[var(--text-muted)]">推荐交易所</div>
                  </div>
                </div>
                <div class="mb-3 p-2 bg-black/40 rounded-lg border border-white/5">
                  <div class="text-[9px] text-[var(--text-muted)] mb-0.5">邀请码</div>
                  <div class="flex items-center justify-between gap-2">
                    <span class="font-mono text-[#F0B90B] text-xs font-bold select-all truncate">CPA_00ZIV33RO4</span>
                    <button onclick="navigator.clipboard.writeText('CPA_00ZIV33RO4').then(()=>{this.textContent='已复制';setTimeout(()=>this.textContent='复制',1500)})" class="px-1.5 py-0.5 text-[9px] rounded bg-white/5 hover:bg-white/10 text-[var(--text-muted)] transition-colors cursor-pointer shrink-0">复制</button>
                  </div>
                </div>
                <a href="https://accounts.binance.com/register?ref=CPA_00ZIV33RO4" target="_blank" rel="sponsored"
                   class="block w-full text-center px-3 py-2 bg-[#F0B90B] hover:bg-[#d4a009] text-black text-xs font-bold rounded-lg transition-colors">
                  注册 →
                </a>
              </div>
            </div>

            <!-- Ad Card 2: TradingView -->
            <div class="card overflow-hidden">
              <div class="p-4 bg-[#0f1419] border border-white/5 rounded-xl">
                <div class="flex items-center gap-2 mb-3">
                  <div class="w-8 h-8 rounded-lg bg-[#2962FF] flex items-center justify-center text-white font-bold text-xs">TV</div>
                  <div>
                    <div class="text-white font-semibold text-xs">TradingView</div>
                    <div class="text-[10px] text-[var(--text-muted)]">图表分析</div>
                  </div>
                </div>
                <p class="text-[10px] text-[var(--text-muted)] mb-3 leading-relaxed">K线分析标配工具，Al Brooks 价格行为学首选。</p>
                <a href="https://www.tradingview.com/gopro/?share_your_love=1HCrypto" target="_blank" rel="sponsored"
                   class="block w-full text-center px-3 py-2 bg-[#2962FF] hover:bg-[#1e4fd8] text-white text-xs font-bold rounded-lg transition-colors">
                  免费试用 →
                </a>
              </div>
            </div>

            <!-- Ad Card 3: Ledger -->
            <div class="card overflow-hidden">
              <div class="p-4 bg-[#0f1419] border border-white/5 rounded-xl">
                <div class="flex items-center gap-2 mb-3">
                  <div class="w-8 h-8 rounded-lg bg-[#00A4E4] flex items-center justify-center text-white font-bold text-xs">L</div>
                  <div>
                    <div class="text-white font-semibold text-xs">Ledger</div>
                    <div class="text-[10px] text-[var(--text-muted)]">硬件钱包</div>
                  </div>
                </div>
                <p class="text-[10px] text-[var(--text-muted)] mb-3 leading-relaxed">离线存储私钥，支持 5500+ 币种。</p>
                <a href="https://shop.ledger.com/?r=5b63cc287be0" target="_blank" rel="sponsored"
                   class="block w-full text-center px-3 py-2 bg-[#00A4E4] hover:bg-[#0088c2] text-white text-xs font-bold rounded-lg transition-colors">
                  官方购买 →
                </a>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-[var(--border)] mt-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">

          <!-- Brand -->
          <div>
            <div class="text-lg font-bold mb-3 gradient-text">1H币研</div>
            <p class="text-sm text-[var(--text-muted)] leading-relaxed mb-4">
              {lang === "zh"
                ? "用阿尔·布鲁克斯价格行为学做 BTC & ETH 日内分析。每日四维研判：价格行为 + 链上数据 + 衍生品 + 模拟盘。"
                : "BTC & ETH intraday analysis using Al Brooks price action methodology. Daily multi-dimensional research."}
            </p>
            <!-- Social Icons -->
            <div class="flex gap-3">
              <a href="https://twitter.com/intent/tweet?url=https://1hcrypto.com&text=1H%E5%B8%81%E7%A0%94%20-%20%E6%AF%8F%E6%97%A5BTC%26ETH%E4%BB%B7%E6%A0%BC%E8%A1%8C%E4%B8%BA%E5%88%86%E6%9E%90" target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-lg bg-[var(--bg-card)] border border-[var(--border)] flex items-center justify-center text-[var(--text-muted)] hover:text-primary hover:border-primary/50 transition-colors" aria-label="分享到 X">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.657l-5.214-6.817-5.979 6.817h-3.309l7.733-8.835-8.168-10.665h6.994l4.83 6.37 5.623-6.37zm-1.161 17.522h1.833l-11.966-15.616h-1.928l11.061 15.616z"/></svg>
