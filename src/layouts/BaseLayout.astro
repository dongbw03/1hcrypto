    <!-- 增强特效脚本：主题切换 / 滚动进度条 / 光晕 / 滚动触发 / 3D 卡片 / 数字动画 / 打字效果 -->
    <script>
      // 0. 主题切换
      (function() {
        const saved = localStorage.getItem("theme");
        const theme = saved || "dark";
        const icon = document.getElementById("theme-icon");
        if (!icon) return;
        if (theme === "light") {
          document.documentElement.setAttribute("data-theme", "light");
          icon.textContent = "🌙";
        } else {
          document.documentElement.removeAttribute("data-theme");
          icon.textContent = "☀️";
        }
        document.getElementById("theme-toggle-btn")?.addEventListener("click", () => {
          const isDark = document.documentElement.getAttribute("data-theme") !== "light";
          if (isDark) {
            document.documentElement.setAttribute("data-theme", "light");
            localStorage.setItem("theme", "light");
            icon.textContent = "🌙";
          } else {
            document.documentElement.removeAttribute("data-theme");
            localStorage.setItem("theme", "dark");
            icon.textContent = "☀️";
          }
        });
      })();

      // 1. 滚动进度条
      function initScrollProgress() {
        const bar = document.getElementById("scroll-progress");
        if (!bar) return;
        window.addEventListener("scroll", () => {
          const pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
          bar.style.width = pct + "%";
        }, { passive: true });
      }
      initScrollProgress();

      // 2. 鼠标跟随光晕（桌面端）
      function initCursorGlow() {
        const glow = document.getElementById("cursor-glow");
        if (!glow || window.innerWidth < 768) return;
        let mx = 0, my = 0, cx = 0, cy = 0;
        document.addEventListener("mousemove", e => { mx = e.clientX; my = e.clientY; }, { passive: true });
        (function anim() {
          cx += (mx - cx) * 0.12;
          cy += (my - cy) * 0.12;
          glow.style.left = cx + "px";
          glow.style.top  = cy + "px";
          requestAnimationFrame(anim);
        })();
      }
      initCursorGlow();

      // 3. 滚动视口触发 fadeIn
      function initFadeIn() {
        const items = document.querySelectorAll(".fade-in-on-scroll");
        if (!items.length) return;
        // 清除已有的 visible 类，防止页面切换后元素已经带 visible 但 opacity 没生效
        items.forEach(el => el.classList.remove("visible"));
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((e, i) => {
            if (e.isIntersecting) {
              setTimeout(() => e.target.classList.add("visible"), i * 80);
              observer.unobserve(e.target);
            }
          });
        }, { threshold: 0.15 });
        items.forEach(el => observer.observe(el));
      }
      initFadeIn();

      // 4. 卡片 3D 倾斜效果
      function initCard3D() {
        document.querySelectorAll(".card-3d").forEach(el => {
          const inner = el.querySelector(".card-3d-inner") || el;
          // 移除旧监听器避免重复绑定（通过克隆替换元素）
          const newEl = el.cloneNode(true);
          el.parentNode.replaceChild(newEl, el);
          const newInner = newEl.querySelector(".card-3d-inner") || newEl;
          newEl.addEventListener("mousemove", e => {
            const rect = newEl.getBoundingClientRect();
            const x = (e.clientX - rect.left) / rect.width  - 0.5;
            const y = (e.clientY - rect.top)  / rect.height - 0.5;
            newInner.style.transform = `rotateY(${x * 8}deg) rotateX(${-y * 8}deg) scale(1.02)`;
          });
          newEl.addEventListener("mouseleave", () => {
            newInner.style.transform = "rotateY(0) rotateX(0) scale(1)";
          });
        });
      }
      initCard3D();

      // 5. 数字滚动动画（进入视口时触发）
      function initMetricCount() {
        const els = document.querySelectorAll(".metric-value");
        if (!els.length) return;
        const obs = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (!e.isIntersecting) return;
            const el = e.target;
            const txt = el.textContent.trim();
            if (txt === "--" || txt === "-,---" || txt === "--,---" || txt === "---") return;
            const nums = txt.replace(/[^0-9.]/g, "");
            if (!nums || nums === "0") return;
            const target = parseFloat(nums.replace(/,/g, ""));
            if (isNaN(target)) return;
            const suffix = txt.replace(/[0-9,.]/g, "").trim();
            const duration = 1500;
            const start = performance.now();
            el.textContent = "0" + (suffix ? " " + suffix : "");
            el.classList.add("metric-animate");
            function update(now) {
              const pct = Math.min((now - start) / duration, 1);
              const eased = 1 - Math.pow(1 - pct, 3);
              const val = Math.round(eased * target);
              el.textContent = val.toLocaleString() + (suffix ? " " + suffix : "");
              if (pct < 1) requestAnimationFrame(update);
            }
            requestAnimationFrame(update);
            obs.unobserve(el);
          });
        }, { threshold: 0.5 });
        els.forEach(el => obs.observe(el));
      }
      initMetricCount();

      // 6. 打字机效果（应用于 .typing-effect 元素）
      function initTypingEffect() {
        const el = document.querySelector(".typing-effect");
        if (!el) return;
        const text = el.dataset.typingText || el.textContent.trim();
        el.dataset.typingText = text;
        el.textContent = "";
        let i = 0;
        const speed = 50;
        el.classList.add("typing-cursor");
        function type() {
          if (i < text.length) {
            el.textContent += text.charAt(i);
            i++;
            setTimeout(type, speed + Math.random() * 30);
          } else {
            el.classList.remove("typing-cursor");
          }
        }
        const obs = new IntersectionObserver((entries) => {
          if (entries[0].isIntersecting) { setTimeout(type, 300); obs.unobserve(el); }
        }, { threshold: 0.5 });
        obs.observe(el);
      }
      initTypingEffect();

      // Astro View Transitions 页面切换后重新初始化所有效果
      document.addEventListener('astro:page-load', () => {
        initFadeIn();
        initCard3D();
        initMetricCount();
        initTypingEffect();
      });

      // 兜底：3秒后强制显示所有 fade-in-on-scroll 元素（防止 IntersectionObserver 失效）
      setTimeout(() => {
        document.querySelectorAll('.fade-in-on-scroll:not(.visible)').forEach(el => {
          el.classList.add('visible');
        });
      }, 3000);
    </script>
