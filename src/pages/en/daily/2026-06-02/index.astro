---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
---
<BaseLayout title="BTC/USDT 1H Price Action - 2026-06-02 | 1H Crypto" description="BTC 当前报价 $71,111。等待市场数据接入后更新完整分析。…" lang="en" activeNav="daily">
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "BTC/USDT 1H Price Action - 2026-06-02",
    "description": "BTC 当前报价 $71,111。等待市场数据接入后更新完整分析。",
    "datePublished": "2026-06-02T08:00:00+08:00",
    "dateModified": "2026-06-02T00:52:10+08:00",
    "author": {"@type": "Person", "name": "1H Crypto Trader"},
    "publisher": {"@type": "Organization", "name": "1H Crypto"}
  }</script>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-8 fade-in-on-scroll">
      <div class="flex items-center gap-2 mb-3">
        <span class="badge-red">Bearish</span>
        <span class="text-xs text-[var(--text-muted)]">BTC/USDT</span>
        <span class="text-xs text-[var(--text-muted)]">2026-06-02</span>
      </div>
      <h1 class="text-3xl font-bold text-white mb-3">BTC/USDT 1H Price Action</h1>
      <p class="text-[var(--text-secondary)] text-lg">BTC 当前报价 $71,111。等待市场数据接入后更新完整分析。…</p>
    </div>

    <div class="p-5 bg-[var(--bg-secondary)] rounded-xl mb-8 border-l-4 border-primary">
      <p class="text-xs text-primary font-semibold mb-2">📌 Key Takeaways</p>
      <p class="text-sm text-[var(--text-primary)] leading-relaxed">BTC 当前报价 $71,111。等待市场数据接入后更新完整分析。</p>
    </div>

    <div class="card p-6 mb-6">
      <h2 class="text-white font-semibold mb-4">📊 Market Structure</h2>
      <p class="text-sm text-[var(--text-primary)] mb-4">CoinGecko 实时价格：$71,111。24h 变化：-3.71%。</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">R2</div><div class="text-sm font-bold text-white font-mono">0</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">R1</div><div class="text-sm font-bold text-white font-mono">0</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center border border-primary/30"><div class="text-xs text-primary">Pivot</div><div class="text-sm font-bold text-primary font-mono">0</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">S1</div><div class="text-sm font-bold text-white font-mono">0</div></div>
      </div>
    </div>

    <div class="card p-6 mb-6">
      <h2 class="text-white font-semibold mb-4">⛓️ On-Chain Snapshot</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center">
          <div class="text-xs text-[var(--text-muted)]">Exchange Balance</div>
          <div class="text-sm font-bold font-mono text-green-400">-3,200</div>
        </div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center">
          <div class="text-xs text-[var(--text-muted)]">OI Change</div>
          <div class="text-sm font-bold font-mono text-accent">+2.1%</div>
        </div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center">
          <div class="text-xs text-[var(--text-muted)]">Funding Rate</div>
          <div class="text-sm font-bold font-mono text-accent">0.03%</div>
        </div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center">
          <div class="text-xs text-[var(--text-muted)]">Net Flow (7d)</div>
          <div class="text-sm font-bold font-mono text-green-400">-1,800</div>
        </div>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-[var(--border)] flex flex-wrap gap-4 text-sm">
      <a href="/en/trading/" class="text-primary hover:underline no-underline">📊 Paper Trading</a>
      <a href="/en/analysis/" class="text-primary hover:underline no-underline">📈 Price Analysis</a>
      <a href="/en/learn/" class="text-primary hover:underline no-underline">📚 Learning Center</a>
    </div>
  </div>
</BaseLayout>
