          {n:"Gate.io",c:"Gate",k:"1hcrypto",u:"https://www.gate.io/signup/1hcrypto"},
          {n:"KuCoin",c:"KuCoin",k:"1hcrypto",u:"https://www.kucoin.com/r/af/1hcrypto"},
          {n:"MEXC",c:"MEXC",k:"1hcrypto",u:"https://www.mexc.com/register?inviteCode=1hcrypto"},
          {n:"BingX",c:"BingX",k:"1hcrypto",u:"https://bingx.com/invite/1hcrypto"},
          {n:"CoinW",c:"CoinW",k:"1hcrypto",u:"https://www.coinw.com/front/register?r=1hcrypto"},
