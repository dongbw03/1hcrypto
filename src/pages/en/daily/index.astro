---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { readFileSync } from 'fs';
import matter from 'gray-matter';


// 读取 latest-analysis.json
let analysis = null;
try {
  const raw = readFileSync('src/data/latest-analysis.json', 'utf-8');
  analysis = JSON.parse(raw);
} catch (e) {}
const dailyFilesEn = new (require('fs')).readdirSync('src/content/en/daily')
  .filter(f => f.endsWith('.md')).sort().reverse();
const latestFileEn = dailyFilesEn[0];
let dataEn = {
  title: 'BTC & ETH Hourly Price Action',
  date: '2026-06-03',
  description: 'BTC/USDT & ETH/USDT hourly price action analysis.',
  btc_entry: 0, btc_stop: 0, btc_tp1: 0, btc_tp2: 0,
  eth_entry: 0, eth_stop: 0, eth_tp1: 0, eth_tp2: 0,
};
let contentEn = '';
if (latestFileEn) {
  try {
    const raw = readFileSync(`src/content/en/daily/${latestFileEn}`, 'utf-8');
    const parsed = matter(raw);
    dataEn = { ...dataEn, ...parsed.data };
    contentEn = parsed.content || '';
  } catch (e) {}
}
const fmtEn = (n) => n ? n.toLocaleString() : '—';
const btcEn = contentEn.split('## ETH')[0] || '';
const ethEn = contentEn.split('## ETH')[1]?.split('##')[0] || '';

const fmt = (n) => {
  if (!n && n !== 0) return '—';
  return Number(n).toLocaleString();
};

const today = dataEn.date || analysis?.date || '2026-06-03';

// 从 latest-analysis.json 获取数据
const btc = analysis?.btc || {};
const eth = analysis?.eth || {};
const onchainData = analysis?.onchain || {};
const btcOnchain = onchainData?.btc || {};
const ethOnchain = onchainData?.eth || {};

// BTC fallback
const btcEntry = btc.entry || dataEn.btc_entry || 71500;
const btcStop = btc.stop || dataEn.btc_stop || 70200;
const btcTp1 = btc.tp1 || dataEn.btc_tp1 || 73000;
const btcTp2 = btc.tp2 || dataEn.btc_tp2 || 74800;
const btcPivot = btc.pivot || 71000;
const btcR2 = btc.resistance?.[0] || 73600;
const btcR1 = btc.resistance?.[1] || 71500;
const btcS1 = btc.support?.[0] || 70000;
const btcS2 = btc.support?.[1] || 68500;

// ETH fallback
const ethEntry = eth.entry || dataEn.eth_entry || 2050;
const ethStop = eth.stop || dataEn.eth_stop || 1980;
const ethTp1 = eth.tp1 || dataEn.eth_tp1 || 2120;
const ethTp2 = eth.tp2 || dataEn.eth_tp2 || 2200;
const ethPivot = eth.pivot || 2050;
const ethR2 = eth.resistance?.[0] || 2150;
const ethR1 = eth.resistance?.[1] || 2100;
const ethS1 = eth.support?.[0] || 1980;
const ethS2 = eth.support?.[1] || 1920;

<BaseLayout title={`Daily Analysis - ${dataEn.title} | 1H Crypto`} description={dataEn.description} lang="en" activeNav="daily">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Daily Analysis - BTC & ETH Hourly Price Action",
    "description": "BTC/USDT & ETH/USDT hourly price action analysis.",
    "image": { "@type": "ImageObject", "url": "https://1hcrypto.com/og-default.png", "width": 1200, "height": 630 },
    "datePublished": "2026-06-03T00:00:00+08:00",
    "dateModified": new Date().toISOString(),
    "author": { "@type": "Person", "name": "1H Crypto Trader" },
    "publisher": { "@type": "Organization", "name": "1H Crypto Research" }
  })}></script>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-8 fade-in-on-scroll">
      <div class="flex items-center gap-2 mb-2">
        <span class="badge badge-blue">Daily Analysis</span>
        <span class="text-xs text-[var(--text-muted)] font-mono">{today}</span>
      </div>
      <h1 class="text-3xl font-bold text-white mb-2">{dataEn.title}</h1>
      <p class="text-[var(--text-muted)]">Al Brooks Framework · Published 8:00 AM · with Entry/Stop/TP Reference</p>
    </div>

    <!-- BTC -->
    <div class="card p-6 mb-6 hover:border-primary/30 transition-colors fade-in-on-scroll border-t-4 border-t-primary">
      <div class="flex items-center gap-2 mb-4">
        <span class="badge badge-blue">BTC/USDT</span>
        <span class="text-xs text-[var(--text-muted)] font-mono">5 min read</span>
      </div>
      <h2 class="text-xl font-bold text-white mb-3">Price Action Analysis</h2>
      <p class="text-sm text-[var(--text-secondary)] mb-4">Consolidation after selling pressure · Watch 71,500 breakout confirmation · Bears dominant, wait for signal</p>
      <div class="p-4 bg-[var(--bg-secondary)] rounded-lg mb-4 border-l-3 border-primary">
        <p class="text-xs text-primary font-semibold mb-2">📌 Core Summary</p>
        <p class="text-sm text-[var(--text-primary)] leading-relaxed">
          <strong>Market Structure:</strong> Down trend day, consolidating 70,800-71,500, volume drying up.<br/>
          <strong>Key Level:</strong> $71,500 — coincides with previous high & resistance.<br/>
          <strong>Core Judgment:</strong> Wait for breakout above 71,500 confirmation or test of 70,000 support before entry. Do not chase shorts.
        </p>
      </div>
      <h3 class="text-white font-semibold mb-2">Entry Reference</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-4 text-center border border-white/5">
          <div class="text-xs text-[var(--text-muted)]">Entry</div>
          <div class="text-lg font-bold text-white font-mono">{fmt(btcEntry)}</div>
        </div>
        <div class="bg-red-500/5 rounded-lg p-4 text-center border border-red-500/10">
          <div class="text-xs text-red-400">Stop</div>
          <div class="text-lg font-bold text-red-400 font-mono">{fmt(btcStop)}</div>
        </div>
        <div class="bg-green-500/5 rounded-lg p-4 text-center border border-green-500/10">
          <div class="text-xs text-green-400">TP1</div>
          <div class="text-lg font-bold text-green-400 font-mono">{fmt(btcTp1)}</div>
        </div>
        <div class="bg-green-500/5 rounded-lg p-4 text-center border border-green-500/10">
          <div class="text-xs text-green-400">TP2</div>
          <div class="text-lg font-bold text-green-400 font-mono">{fmt(btcTp2)}</div>
        </div>
      </div>
      <h3 class="text-white font-semibold mb-2">Key Levels</h3>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-2 mb-4">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">Resistance 2</div><div class="text-sm font-bold text-white font-mono">{fmt(btcR2)}</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">Resistance 1</div><div class="text-sm font-bold text-white font-mono">{fmt(btcR1)}</div></div>
        <div class="bg-primary/10 rounded-lg p-3 text-center border border-primary/30"><div class="text-xs text-primary">★ Pivot</div><div class="text-sm font-bold text-primary font-mono">{fmt(btcPivot)}</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">Support 1</div><div class="text-sm font-bold text-white font-mono">{fmt(btcS1)}</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">Support 2</div><div class="text-sm font-bold text-white font-mono">{fmt(btcS2)}</div></div>
      </div>
      <h3 class="text-white font-semibold mb-2">On-chain Data</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-3">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">BTC Balance</div><div class="text-sm font-bold text-red-400 font-mono">{btcOnchain.exchangeBalance || '-5,200'}</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">Open Interest</div><div class="text-sm font-bold text-red-400 font-mono">{btcOnchain.oiChange || '-3.2%'}</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">Funding Rate</div><div class="text-sm font-bold text-red-400 font-mono">{btcOnchain.funding || '-0.05%'}</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">Net Flow 7d</div><div class="text-sm font-bold text-red-400 font-mono">{btcOnchain.netFlow7d || '-3,100'}</div></div>
      </div>
    </div>

    <!-- ETH -->
    <div class="card p-6 mb-6 hover:border-accent/30 transition-colors fade-in-on-scroll border-t-4 border-t-accent" style="animation-delay:0.1s">
      <div class="flex items-center gap-2 mb-4">
        <span class="badge badge-amber">ETH/USDT</span>
        <span class="text-xs text-[var(--text-muted)] font-mono">4 min read</span>
      </div>
      <h2 class="text-xl font-bold text-white mb-3">Price Action Analysis</h2>
      <p class="text-sm text-[var(--text-secondary)] mb-4">Relatively strong but weak · Watch 2,050 breakout · Volume low, wait for confirmation</p>
      <div class="p-4 bg-[var(--bg-secondary)] rounded-lg mb-4 border-l-3 border-accent">
        <p class="text-xs text-accent font-semibold mb-2">📌 Core Summary</p>
        <p class="text-sm text-[var(--text-primary)] leading-relaxed">
          <strong>Market Structure:</strong> Range-bound, consolidating 1,980-2,050, volume drying up.<br/>
          <strong>Key Level:</strong> $2,050 — recent high & resistance.<br/>
          <strong>Core Judgment:</strong> Leaning bullish but wait for breakout above 2,050 confirmation. Do not front-run.
        </p>
      </div>
      <h3 class="text-white font-semibold mb-2">Entry Reference</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-4 text-center border border-white/5">
          <div class="text-xs text-[var(--text-muted)]">Entry</div>
          <div class="text-lg font-bold text-white font-mono">{fmt(ethEntry)}</div>
        </div>
        <div class="bg-red-500/5 rounded-lg p-4 text-center border border-red-500/10">
          <div class="text-xs text-red-400">Stop</div>
          <div class="text-lg font-bold text-red-400 font-mono">{fmt(ethStop)}</div>
        </div>
        <div class="bg-green-500/5 rounded-lg p-4 text-center border border-green-500/10">
          <div class="text-xs text-green-400">TP1</div>
          <div class="text-lg font-bold text-green-400 font-mono">{fmt(ethTp1)}</div>
        </div>
        <div class="bg-green-500/5 rounded-lg p-4 text-center border border-green-500/10">
          <div class="text-xs text-green-400">TP2</div>
          <div class="text-lg font-bold text-green-400 font-mono">{fmt(ethTp2)}</div>
        </div>
      </div>
      <h3 class="text-white font-semibold mb-2">Key Levels</h3>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-2 mb-4">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">Resistance 2</div><div class="text-sm font-bold text-white font-mono">{fmt(ethR2)}</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">Resistance 1</div><div class="text-sm font-bold text-white font-mono">{fmt(ethR1)}</div></div>
        <div class="bg-accent/10 rounded-lg p-3 text-center border border-accent/30"><div class="text-xs text-accent">★ Neckline</div><div class="text-sm font-bold text-accent font-mono">{fmt(ethPivot)}</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">Support 1</div><div class="text-sm font-bold text-white font-mono">{fmt(ethS1)}</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">Support 2</div><div class="text-sm font-bold text-white font-mono">{fmt(ethS2)}</div></div>
      </div>
      <h3 class="text-white font-semibold mb-2">On-chain Data</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-3">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">ETH Balance</div><div class="text-sm font-bold text-green-400 font-mono">{ethOnchain.exchangeBalance || '-85K'}</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">Open Interest</div><div class="text-sm font-bold text-green-400 font-mono">{ethOnchain.oiChange || '+1.2%'}</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">Funding Rate</div><div class="text-sm font-bold text-[var(--text-muted)] font-mono">{ethOnchain.funding || '0.002%'}</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">Net Flow 7d</div><div class="text-sm font-bold text-red-400 font-mono">{ethOnchain.netFlow7d || '-42K'}</div></div>
      </div>
    </div>

    <!-- Overall Judgment -->
    <div class="card p-6 mb-6 fade-in-on-scroll" style="animation-delay:0.15s">
      <h2 class="text-xl font-bold text-white mb-4">Overall Judgment</h2>
      <div class="text-sm text-[var(--text-secondary)] leading-relaxed">
        <p class="mb-3"><strong>BTC:</strong> Sold off -3.83% yesterday, now consolidating around 70,800 with drying volume. Al Brooks framework: TR (Trading Range) within down trend. Wait for 71,500 breakout confirmation or 70,000 support test before entry. Do not chase shorts — risk/reward unfavorable.</p>
        <p class="mb-3"><strong>ETH:</strong> Relatively strong, only -0.40% drop, outperforming BTC. Consolidating in 1,980-2,050 range. Wait for 2,050 breakout confirmation before leaning bullish.</p>
        <p><strong>Overall:</strong> Market sentiment bearish, BTC leading the drop. Wait for key level breakout confirmations before entry. Strict stop loss discipline.</p>
      </div>
    </div>

    <!-- Paper Trading + Random Referral -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6 fade-in-on-scroll" style="animation-delay:0.2s">
      <a href="/en/trading/" class="card p-5 bg-[var(--bg-secondary)]/40 border border-primary/20 hover:border-primary/50 transition-colors no-underline block">
        <div class="text-sm text-white font-semibold mb-1">📊 View Paper Trading</div>
        <div class="text-xs text-[var(--text-muted)]">$1M USDT · Win 56% · NAV +11.3%</div>
      </a>
      <!-- Random Referral -->
      <div class="card p-5 bg-[var(--bg-card)]/30 border border-[var(--border)]" id="ref-card-en">
        <div class="text-xs text-[var(--text-muted)] leading-relaxed" id="ref-text-en">
          Loading...
        </div>
      </div>
    </div>

    <!-- Random Referral Script -->
    <script>
      (function() {
        const refs = [
          {n:"Binance",c:"Binance",k:"CPA_00ZIV33RO4",u:"https://accounts.binance.com/register?ref=CPA_00ZIV33RO4"},
          {n:"OKX",c:"OKX",k:"1HCRYPTO",u:"https://www.okx.com/join/1HCRYPTO"},
          {n:"Bybit",c:"Bybit",k:"1HCRYPTO",u:"https://www.bybit.com/invite?ref=1HCRYPTO"},
          {n:"Bitget",c:"Bitget",k:"1hcrypto",u:"https://www.bitget.com/expressly?shareCode=1hcrypto"},
          {n:"Gate.io",c:"Gate",k:"1hcrypto",u:"https://www.gate.io/signup/1hcrypto"},
          {n:"KuCoin",c:"KuCoin",k:"1hcrypto",u:"https://www.kucoin.com/r/af/1hcrypto"},
          {n:"MEXC",c:"MEXC",k:"1hcrypto",u:"https://www.mexc.com/register?inviteCode=1hcrypto"},
          {n:"BingX",c:"BingX",k:"1hcrypto",u:"https://bingx.com/invite/1hcrypto"},
          {n:"CoinW",c:"CoinW",k:"1hcrypto",u:"https://www.coinw.com/front/register?r=1hcrypto"},
          {n:"BitMart",c:"BitMart",k:"1hcrypto",u:"https://www.bitmart.com/invite/1hcrypto/en"},
          {n:"XT.com",c:"XT",k:"1hcrypto",u:"https://www.xt.com/en/accounts/register?ref=1hcrypto"}
        ];
        var a = refs.slice();
        for (var i = a.length - 1; i > 0; i--) { var j = Math.floor(Math.random()*(i+1)); var t = a[i]; a[i] = a[j]; a[j] = t; }
        var r1 = a[0], r2 = a[1];
        var el = document.getElementById('ref-text-en');
        if (el) {
          el.innerHTML = '<span class="text-[var(--text-secondary)] font-medium">🤝 Support us:</span> Sign up via <a href="'+r1.u+'" target="_blank" rel="sponsored" class="text-primary hover:underline">'+r1.n+' (code: '+r1.k+')</a> or <a href="'+r2.u+'" target="_blank" rel="sponsored" class="text-accent hover:underline">'+r2.n+' (code: '+r2.k+')</a> — no extra cost, we earn commission.';
        }
      })();
    </script>

    <!-- Ads -->
    <div class="mt-4 border border-dashed border-[var(--border)] rounded-lg p-3 text-center fade-in-on-scroll" style="animation-delay:0.25s">
      <p class="text-xs text-[var(--text-muted)] opacity-50">📢 Ad placement — reserved for AdSense</p>
    </div>

    <!-- Disclaimer -->
    <div class="mt-8 p-4 bg-[var(--bg-card)]/50 border border-[var(--border)] rounded-lg text-xs text-[var(--text-muted)]">
      <strong class="text-[var(--text-secondary)]">⚠️ Disclaimer:</strong> This is personal market observation only, not investment advice. Paper trading uses virtual funds. Trading carries high risk, you bear full responsibility for your decisions.
    </div>
  </div>
</BaseLayout>
