---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import matter from 'gray-matter';
import { marked } from 'marked';

// 读取所有 daily markdown 文件，按日期排序取最新
const modules = await import.meta.glob('../../../content/en/daily/*.md', { eager: true });
const files = Object.entries(modules)
  .map(([filePath, module]) => {
    try {
      const { data, content } = matter(module.rawContent());
      return { filePath, data: data || {}, content: content || '' };
    } catch (e) {
      return null;
    }
  })
  .filter(f => f && f.data && f.data.date)
  .sort((a, b) => (b.data.date || '').localeCompare(a.data.date || ''));

const latest = files[0] || { 
  data: { title:'',date:'2026-06-02',description:'',sentiment:'',keywords:'',btc_entry:0,btc_stop:0,btc_tp1:0,btc_tp2:0,eth_entry:0,eth_stop:0,eth_tp1:0,eth_tp2:0 }, 
  content: '' 
};

const { data, content } = latest;

// 解析 BTC 和 ETH 部分
function parseSection(sectionText) {
  const marketStructure = (sectionText.match(/\*\*Market Structure\*\*　([\s\S]*?)(?=\*\*Core Judgment\*\*)/) || [])[1] || '';
  const coreJudgment = (sectionText.match(/\*\*Core Judgment\*\*　([\s\S]*?)(?=\*\*Key Levels\*\*)/) || [])[1] || '';
  const levelsRaw = (sectionText.match(/\*\*Key Levels\*\*([\s\S]*?)(?=\*\*On-chain Snapshot\*\*)/) || [])[1] || '';
  const levels = levelsRaw ? marked.parse(levelsRaw) : '';
  const onchainRaw = (sectionText.match(/\*\*On-chain Snapshot\*\*([\s\S]*?)$/) || [])[1] || '';
  const onchain = onchainRaw ? marked.parse(onchainRaw) : '';
  return { marketStructure: marketStructure.trim(), coreJudgment: coreJudgment.trim(), levels, onchain };
}

const btcSection = (content.match(/## BTC[\s\S]*?(?=## ETH|$)/) || [])[0] || '';
const ethSection = (content.match(/## ETH[\s\S]*?(?=## Overall|$)/) || [])[0] || '';

const btc = parseSection(btcSection);
const eth = parseSection(ethSection);

// 解析综合判断
const overall = (content.match(/## Overall Judgment([\s\S]*?)$/) || [])[1] || '';
const overallHtml = overall ? marked.parse(overall) : '';

// 格式化数字
function fmt(n) { return n ? n.toLocaleString('en-US') : '—'; }
---

<BaseLayout title={`Daily Analysis - BTC & ETH | 1H Crypto`} description={data.description || "BTC/USDT & ETH/USDT hourly price action analysis."} lang="en" activeNav="daily">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": data.title || "Daily Analysis - BTC & ETH Hourly Price Action",
    "description": data.description || "",
    "image": { "@type": "ImageObject", "url": "https://1hcrypto.com/og-default.png", "width": 1200, "height": 630 },
    "datePublished": (data.date || '2026-06-02') + "T00:00:00+08:00",
    "dateModified": new Date().toISOString(),
    "author": { "@type": "Person", "name": "1H Crypto Trader" },
    "publisher": { "@type": "Organization", "name": "1H Crypto Research" }
  })}></script>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-8 fade-in-on-scroll">
      <div class="flex items-center gap-2 mb-2">
        <span class="badge badge-blue">Daily</span>
        <span class="text-xs text-[var(--text-muted)] font-mono">{data.date || '2026-06-02'}</span>
      </div>
      <h1 class="text-3xl font-bold text-white mb-2">{data.title || 'BTC & ETH Hourly Price Action'}</h1>
      <p class="text-[var(--text-muted)]">Al Brooks Framework · Published 8:00 AM · with Entry/Stop/TP Reference</p>
    </div>

    <!-- BTC -->
    <div class="card p-6 mb-6 hover:border-primary/30 transition-colors fade-in-on-scroll border-t-4 border-t-primary">
      <div class="flex items-center gap-2 mb-4">
        <span class="badge badge-blue">BTC/USDT</span>
        <span class="text-xs text-[var(--text-muted)] font-mono">5 min read</span>
      </div>
      <h2 class="text-xl font-bold text-white mb-3">Price Action Analysis</h2>
      <p class="text-sm text-[var(--text-secondary)] mb-4">{btc.marketStructure || 'Market structure data loading...'}</p>
      
      <div class="p-4 bg-[var(--bg-secondary)] rounded-lg mb-4 border-l-3 border-primary">
        <p class="text-xs text-primary font-semibold mb-2">📌 Key Takeaways</p>
        <p class="text-sm text-[var(--text-primary)] leading-relaxed">
          <strong>Structure:</strong> {btc.marketStructure || '—'}<br/>
          <strong>Core Judgment:</strong> {btc.coreJudgment || '—'}
        </p>
      </div>

      <h3 class="text-white font-semibold mb-2">Entry Reference</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-4 text-center border border-white/5">
          <div class="text-xs text-[var(--text-muted)]">Entry</div>
          <div class="text-lg font-bold text-white font-mono">{fmt(data.btc_entry)}</div>
        </div>
        <div class="bg-red-500/5 rounded-lg p-4 text-center border border-red-500/10">
          <div class="text-xs text-red-400">Stop</div>
          <div class="text-lg font-bold text-red-400 font-mono">{fmt(data.btc_stop)}</div>
        </div>
        <div class="bg-green-500/5 rounded-lg p-4 text-center border border-green-500/10">
          <div class="text-xs text-green-400">TP1</div>
          <div class="text-lg font-bold text-green-400 font-mono">{fmt(data.btc_tp1)}</div>
        </div>
        <div class="bg-green-500/5 rounded-lg p-4 text-center border border-green-500/10">
          <div class="text-xs text-green-400">TP2</div>
          <div class="text-lg font-bold text-green-400 font-mono">{fmt(data.btc_tp2)}</div>
        </div>
      </div>

      <h3 class="text-white font-semibold mb-2">Key Levels</h3>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-2 mb-4" set:html={btc.levels}></div>

      <h3 class="text-white font-semibold mb-2">On-chain Data</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-3" set:html={btc.onchain}></div>
    </div>

    <!-- ETH -->
    <div class="card p-6 mb-6 hover:border-accent/30 transition-colors fade-in-on-scroll border-t-4 border-t-accent" style="animation-delay:0.1s">
      <div class="flex items-center gap-2 mb-4">
        <span class="badge badge-amber">ETH/USDT</span>
        <span class="text-xs text-[var(--text-muted)] font-mono">4 min read</span>
      </div>
      <h2 class="text-xl font-bold text-white mb-3">Price Action Analysis</h2>
      <p class="text-sm text-[var(--text-secondary)] mb-4">{eth.marketStructure || 'Market structure data loading...'}</p>
      
      <div class="p-4 bg-[var(--bg-secondary)] rounded-lg mb-4 border-l-3 border-accent">
        <p class="text-xs text-accent font-semibold mb-2">📌 Key Takeaways</p>
        <p class="text-sm text-[var(--text-primary)] leading-relaxed">
          <strong>Structure:</strong> {eth.marketStructure || '—'}<br/>
          <strong>Core Judgment:</strong> {eth.coreJudgment || '—'}
        </p>
      </div>

      <h3 class="text-white font-semibold mb-2">Entry Reference</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-4 text-center border border-white/5">
          <div class="text-xs text-[var(--text-muted)]">Entry</div>
          <div class="text-lg font-bold text-white font-mono">{fmt(data.eth_entry)}</div>
        </div>
        <div class="bg-red-500/5 rounded-lg p-4 text-center border border-red-500/10">
          <div class="text-xs text-red-400">Stop</div>
          <div class="text-lg font-bold text-red-400 font-mono">{fmt(data.eth_stop)}</div>
        </div>
        <div class="bg-green-500/5 rounded-lg p-4 text-center border border-green-500/10">
          <div class="text-xs text-green-400">TP1</div>
          <div class="text-lg font-bold text-green-400 font-mono">{fmt(data.eth_tp1)}</div>
        </div>
        <div class="bg-green-500/5 rounded-lg p-4 text-center border border-green-500/10">
          <div class="text-xs text-green-400">TP2</div>
          <div class="text-lg font-bold text-green-400 font-mono">{fmt(data.eth_tp2)}</div>
        </div>
      </div>

      <h3 class="text-white font-semibold mb-2">Key Levels</h3>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-2 mb-4" set:html={eth.levels}></div>

      <h3 class="text-white font-semibold mb-2">On-chain Data</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-2 mb-3" set:html={eth.onchain}></div>
    </div>

    <!-- Overall Judgment -->
    {overallHtml && (
      <div class="card p-6 mb-6 fade-in-on-scroll" style="animation-delay:0.15s">
        <h2 class="text-xl font-bold text-white mb-4">Overall Judgment</h2>
        <div class="text-sm text-[var(--text-secondary)] leading-relaxed" set:html={overallHtml}></div>
      </div>
    )}

    <!-- Paper Trading + Random Referral -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6 fade-in-on-scroll" style="animation-delay:0.2s">
      <a href="/en/trading/" class="card p-5 bg-[var(--bg-secondary)]/40 border border-primary/20 hover:border-primary/50 transition-colors no-underline block">
        <div class="text-sm text-white font-semibold mb-1">📊 View Paper Trading</div>
        <div class="text-xs text-[var(--text-muted)]">$1M USDT · Win 56% · NAV +11.3%</div>
      </a>
