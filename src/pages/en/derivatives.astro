---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';

// Read derivatives data at build time
let derivativesData = null;
let error = null;

try {
  const filePath = path.join(process.cwd(), 'src/data/derivatives.json');
  if (fs.existsSync(filePath)) {
    const fileContent = fs.readFileSync(filePath, 'utf-8');
    derivativesData = JSON.parse(fileContent);
  }
} catch (err) {
  error = err.message;
}

// Process data for display
let btcData = null;
let ethData = null;

if (derivativesData && derivativesData.symbols) {
  btcData = derivativesData.symbols['BTCUSDT'];
  ethData = derivativesData.symbols['ETHUSDT'];
}

// Sentiment color mapping
const sentimentColors = {
  'bullish': 'bg-green-500/20 text-green-400 border border-green-500/30',
  'bearish': 'bg-red-500/20 text-red-400 border border-red-500/30',
  'contrarian_bullish': 'bg-yellow-500/20 text-yellow-400 border border-yellow-500/30',
  'contrarian_bearish': 'bg-yellow-500/20 text-yellow-400 border border-yellow-500/30',
  'neutral': 'bg-gray-500/20 text-gray-400 border border-gray-500/30'
};

const sentimentLabels = {
  'zh': {
    'bullish': '看涨',
    'bearish': '看跌',
    'contrarian_bullish': '逆向看涨',
    'contrarian_bearish': '逆向看跌',
    'neutral': '中性'
  },
  'en': {
    'bullish': 'Bullish',
    'bearish': 'Bearish',
    'contrarian_bullish': 'Contrarian Bullish',
    'contrarian_bearish': 'Contrarian Bearish',
    'neutral': 'Neutral'
  }
};
---


  <script type="application/ld+json" set:html={`{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Derivatives Market Sentiment - 1H Crypto",
  "description": "Crypto price action analysis",
  "image": {
    "@type": "ImageObject",
    "url": "https://1hcrypto.com/og-default.png",
    "width": 1200,
    "height": 630
  },
  "datePublished": "2026-05-31T16:20:03+08:00",
  "dateModified": "2026-05-31T16:20:03+08:00",
  "author": {
    "@type": "Person",
    "name": "1H Crypto Trader"
  },
  "publisher": {
    "@type": "Organization",
    "name": "1H Crypto",
    "logo": {
      "@type": "ImageObject",
      "url": "https://1hcrypto.com/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "@id",
    "@id": "https://1hcrypto.com/en/derivatives/"
  }
}`}></script>
<BaseLayout title="Derivatives Market Sentiment - 1H Crypto" lang="en" activeNav="derivatives">
  <div class="min-h-screen bg-[var(--bg-primary)] text-[var(--text-primary)]">
    <section class="py-12 px-4 max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          Derivatives Market Sentiment
        </h1>
        <p class="text-lg text-[var(--text-muted)] max-w-2xl mx-auto">
          Real-time Binance Futures data: funding rate, open interest, long/short ratio, top trader positions, taker buy/sell ratio
        </p>
        {derivativesData && (
          <p class="text-sm text-[var(--text-muted)] mt-4">
            Last updated: {new Date(derivativesData.timestamp).toLocaleString('en-US', { timeZone: 'Asia/Shanghai' })}
          </p>
        )}
      </div>

      {error && (
        <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-6 mb-8">
          <p class="text-red-400">⚠️ Failed to load data: {error}</p>
          <p class="text-sm text-[var(--text-muted)] mt-2">Please run: python scripts/fetch_derivatives.py</p>
        </div>
      )}

      <!-- BTC and ETH Data Cards -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-12">
        <!-- BTC Data -->
        {btcData && (
          <div class="bg-[var(--bg-card)] border border-[var(--border)] p-6 rounded-2xl">
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 text-yellow-500 text-2xl font-bold">₿</div>
                <div>
                  <h2 class="text-2xl font-bold">BTC</h2>
                  <p class="text-sm text-[var(--text-muted)]">BTC/USDT Perpetual</p>
                </div>
              </div>
              {btcData.sentiment_analysis && (
                <span class:list={["px-3 py-1 rounded-full text-sm font-medium", sentimentColors[btcData.sentiment_analysis.sentiment] || 'bg-gray-500/20 text-gray-400']}>
                  {sentimentLabels['en'][btcData.sentiment_analysis.sentiment] || btcData.sentiment_analysis.sentiment}
                </span>
              )}
            </div>

            <div class="grid grid-cols-2 gap-4 mb-6">
              <!-- Funding Rate -->
              {btcData.funding_rate && btcData.funding_rate.length > 0 && (
                <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                  <p class="text-sm text-[var(--text-muted)] mb-1">Funding Rate</p>
                  <p class:list={["text-2xl font-bold", btcData.funding_rate[btcData.funding_rate.length - 1].rate > 0 ? 'text-green-500' : 'text-red-500']}>
                    {btcData.funding_rate[btcData.funding_rate.length - 1].rate > 0 ? '+' : ''}
                    {btcData.funding_rate[btcData.funding_rate.length - 1].rate.toFixed(4)}%
                  </p>
                  <p class="text-xs text-[var(--text-muted)] mt-1">Latest</p>
                </div>
              )}

              <!-- Open Interest -->
              {btcData.open_interest && (
                <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                  <p class="text-sm text-[var(--text-muted)] mb-1">Open Interest</p>
                  <p class="text-2xl font-bold">
                    {new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(btcData.open_interest.open_interest)}
                  </p>
                  <p class="text-xs text-[var(--text-muted)] mt-1">BTC</p>
                </div>
              )}
            </div>

            <!-- Long/Short Ratio -->
            {btcData.long_short_ratio && btcData.long_short_ratio.length > 0 && (
              <div class="mb-6">
                <h3 class="text-lg font-semibold mb-3">Long/Short Account Ratio</h3>
                <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-sm text-[var(--text-muted)]">Long</span>
                    <span class="text-green-500 font-bold">
                      {(btcData.long_short_ratio[btcData.long_short_ratio.length - 1].long_ratio * 100).toFixed(1)}%
                    </span>
                  </div>
                  <div class="w-full bg-[var(--bg-primary)]/30 rounded-full h-3 mb-2">
                    <div 
                      class="bg-green-500 h-3 rounded-full" 
                      style={`width: ${btcData.long_short_ratio[btcData.long_short_ratio.length - 1].long_ratio * 100}%`}
                    ></div>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-[var(--text-muted)]">Short</span>
                    <span class="text-red-500 font-bold">
                      {(btcData.long_short_ratio[btcData.long_short_ratio.length - 1].short_ratio * 100).toFixed(1)}%
                    </span>
                  </div>
                </div>
                <p class="text-xs text-[var(--text-muted)] mt-2">
                  Extreme values (&gt;60% or &lt;40%) may signal reversal.
                </p>
              </div>
            )}

            <!-- Top Trader Ratio -->
            {btcData.top_trader_ls_ratio && btcData.top_trader_ls_ratio.length > 0 && (
              <div class="mb-6">
                <h3 class="text-lg font-semibold mb-3">Top Trader Ratio</h3>
                <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-sm text-[var(--text-muted)]">Top Trader Long</span>
                    <span class="text-green-500 font-bold">
                      {(btcData.top_trader_ls_ratio[btcData.top_trader_ls_ratio.length - 1].long_ratio * 100).toFixed(1)}%
                    </span>
                  </div>
                  <div class="w-full bg-[var(--bg-primary)]/30 rounded-full h-3 mb-2">
                    <div 
                      class="bg-blue-500 h-3 rounded-full" 
                      style={`width: ${btcData.top_trader_ls_ratio[btcData.top_trader_ls_ratio.length - 1].long_ratio * 100}%`}
                    ></div>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-[var(--text-muted)]">Top Trader Short</span>
                    <span class="text-red-500 font-bold">
                      {(btcData.top_trader_ls_ratio[btcData.top_trader_ls_ratio.length - 1].short_ratio * 100).toFixed(1)}%
                    </span>
                  </div>
                </div>
                <p class="text-xs text-[var(--text-muted)] mt-2">
                  Often considered the "smart money" direction.
                </p>
              </div>
            )}

            <!-- Taker Buy/Sell Ratio -->
            {btcData.taker_longshort_ratio && btcData.taker_longshort_ratio.length > 0 && (
              <div>
                <h3 class="text-lg font-semibold mb-3">Taker Buy/Sell Ratio</h3>
                <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-[var(--text-muted)]">Taker Buy / Taker Sell</span>
                    <span class="text-yellow-500 font-bold">
                      {btcData.taker_longshort_ratio[btcData.taker_longshort_ratio.length - 1].buy_sell_ratio.toFixed(2)}
                    </span>
                  </div>
                  <p class="text-xs text-[var(--text-muted)] mt-1">
                    {btcData.taker_longshort_ratio[btcData.taker_longshort_ratio.length - 1].buy_sell_ratio > 1 
                      ? 'More buying pressure from takers' 
                      : 'More selling pressure from takers'}
                  </p>
                </div>
              </div>
            )}
          </div>
        )}

        <!-- ETH Data -->
        {ethData && (
          <div class="bg-[var(--bg-card)] border border-[var(--border)] p-6 rounded-2xl">
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 text-blue-500 text-2xl font-bold">Ξ</div>
                <div>
                  <h2 class="text-2xl font-bold">ETH</h2>
                  <p class="text-sm text-[var(--text-muted)]">ETH/USDT Perpetual</p>
                </div>
              </div>
              {ethData.sentiment_analysis && (
                <span class:list={["px-3 py-1 rounded-full text-sm font-medium", sentimentColors[ethData.sentiment_analysis.sentiment] || 'bg-gray-500/20 text-gray-400']}>
                  {sentimentLabels['en'][ethData.sentiment_analysis.sentiment] || ethData.sentiment_analysis.sentiment}
                </span>
              )}
            </div>

            <div class="grid grid-cols-2 gap-4 mb-6">
              <!-- Funding Rate -->
              {ethData.funding_rate && ethData.funding_rate.length > 0 && (
                <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                  <p class="text-sm text-[var(--text-muted)] mb-1">Funding Rate</p>
                  <p class:list={["text-2xl font-bold", ethData.funding_rate[ethData.funding_rate.length - 1].rate > 0 ? 'text-green-500' : 'text-red-500']}>
                    {ethData.funding_rate[ethData.funding_rate.length - 1].rate > 0 ? '+' : ''}
                    {ethData.funding_rate[ethData.funding_rate.length - 1].rate.toFixed(4)}%
                  </p>
                  <p class="text-xs text-[var(--text-muted)] mt-1">Latest</p>
                </div>
              )}

              <!-- Open Interest -->
              {ethData.open_interest && (
                <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                  <p class="text-sm text-[var(--text-muted)] mb-1">Open Interest</p>
                  <p class="text-2xl font-bold">
                    {new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(ethData.open_interest.open_interest)}
                  </p>
                  <p class="text-xs text-[var(--text-muted)] mt-1">ETH</p>
                </div>
              )}
            </div>

            <!-- Long/Short Ratio -->
            {ethData.long_short_ratio && ethData.long_short_ratio.length > 0 && (
              <div class="mb-6">
                <h3 class="text-lg font-semibold mb-3">Long/Short Account Ratio</h3>
                <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-sm text-[var(--text-muted)]">Long</span>
                    <span class="text-green-500 font-bold">
                      {(ethData.long_short_ratio[ethData.long_short_ratio.length - 1].long_ratio * 100).toFixed(1)}%
                    </span>
                  </div>
                  <div class="w-full bg-[var(--bg-primary)]/30 rounded-full h-3 mb-2">
                    <div 
                      class="bg-green-500 h-3 rounded-full" 
                      style={`width: ${ethData.long_short_ratio[ethData.long_short_ratio.length - 1].long_ratio * 100}%`}
                    ></div>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-[var(--text-muted)]">Short</span>
                    <span class="text-red-500 font-bold">
                      {(ethData.long_short_ratio[ethData.long_short_ratio.length - 1].short_ratio * 100).toFixed(1)}%
                    </span>
                  </div>
                </div>
                <p class="text-xs text-[var(--text-muted)] mt-2">
                  Extreme values (&gt;60% or &lt;40%) may signal reversal.
                </p>
              </div>
            )}

            <!-- Top Trader Ratio -->
            {ethData.top_trader_ls_ratio && ethData.top_trader_ls_ratio.length > 0 && (
              <div class="mb-6">
                <h3 class="text-lg font-semibold mb-3">Top Trader Ratio</h3>
                <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-sm text-[var(--text-muted)]">Top Trader Long</span>
                    <span class="text-green-500 font-bold">
                      {(ethData.top_trader_ls_ratio[ethData.top_trader_ls_ratio.length - 1].long_ratio * 100).toFixed(1)}%
                    </span>
                  </div>
                  <div class="w-full bg-[var(--bg-primary)]/30 rounded-full h-3 mb-2">
                    <div 
                      class="bg-blue-500 h-3 rounded-full" 
                      style={`width: ${ethData.top_trader_ls_ratio[ethData.top_trader_ls_ratio.length - 1].long_ratio * 100}%`}
                    ></div>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-[var(--text-muted)]">Top Trader Short</span>
                    <span class="text-red-500 font-bold">
                      {(ethData.top_trader_ls_ratio[ethData.top_trader_ls_ratio.length - 1].short_ratio * 100).toFixed(1)}%
                    </span>
                  </div>
                </div>
                <p class="text-xs text-[var(--text-muted)] mt-2">
                  Often considered the "smart money" direction.
                </p>
              </div>
            )}

            <!-- Taker Buy/Sell Ratio -->
            {ethData.taker_longshort_ratio && ethData.taker_longshort_ratio.length > 0 && (
              <div>
                <h3 class="text-lg font-semibold mb-3">Taker Buy/Sell Ratio</h3>
                <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-[var(--text-muted)]">Taker Buy / Taker Sell</span>
                    <span class="text-yellow-500 font-bold">
                      {ethData.taker_longshort_ratio[ethData.taker_longshort_ratio.length - 1].buy_sell_ratio.toFixed(2)}
                    </span>
                  </div>
                  <p class="text-xs text-[var(--text-muted)] mt-1">
                    {ethData.taker_longshort_ratio[ethData.taker_longshort_ratio.length - 1].buy_sell_ratio > 1 
                      ? 'More buying pressure from takers' 
                      : 'More selling pressure from takers'}
                  </p>
                </div>
              </div>
            )}
          </div>
        )}
      </div>

      <!-- How to Read This Page -->
      <div class="bg-[var(--bg-card)] border border-[var(--border)] p-6 rounded-2xl">
        <h2 class="text-2xl font-bold mb-6">How to Read This Page</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-lg font-semibold mb-3">Funding Rate</h3>
            <p class="text-[var(--text-secondary)] mb-2">
              Fee paid between longs and shorts. Positive = longs pay shorts (bullish); negative = shorts pay longs (bearish).
            </p>
            <p class="text-sm text-yellow-500">Updated every 8 hours on Binance.</p>
          </div>

          <div>
            <h3 class="text-lg font-semibold mb-3">Open Interest</h3>
            <p class="text-[var(--text-secondary)] mb-2">
              Total value of all open positions. Increasing = money flowing in; decreasing = money flowing out.
            </p>
          </div>

          <div>
            <h3 class="text-lg font-semibold mb-3">Long/Short Account Ratio</h3>
            <p class="text-[var(--text-secondary)] mb-2">
              Long accounts / total accounts. Extreme values (&gt;60% or &lt;40%) may signal reversal.
            </p>
          </div>

          <div>
            <h3 class="text-lg font-semibold mb-3">Top Trader Ratio</h3>
            <p class="text-[var(--text-secondary)] mb-2">
              Long/short ratio of top traders. Often considered the "smart money" direction.
            </p>
          </div>
        </div>
      </div>

      <!-- Affiliate Disclosure -->
      <div class="mt-10 pt-6 border-t border-[var(--border)]">
        <p class="text-sm text-[var(--text-muted)]">Some links on this site are affiliate links. Using them may earn me a commission at no extra cost to you. <a href="/en/disclosure/" class="text-[var(--primary)] hover:underline">See Affiliate Disclosure</a>.</p>
      </div>
    </section>
  </div>
</BaseLayout>
