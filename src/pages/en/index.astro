  <!-- Hero Grid Animation Script -->
  <script>
    (function() {
      const canvas = document.getElementById("grid-canvas-en");
      if (!canvas) return;
      const ctx = canvas.getContext("2d");
      let w, h, points = [];
      function resize() {
        const section = canvas.closest("section");
        w = canvas.width = section.offsetWidth;
        h = canvas.height = section.offsetHeight;
        initPoints();
      }
      function initPoints() {
        points = [];
        const step = 40;
        for (let x = 0; x < w; x += step) {
          for (let y = 0; y < h; y += step) {
            points.push({ x, y, ox: x, oy: y, vx: 0, vy: 0 });
          }
        }
      }
      function draw() {
        ctx.clearRect(0, 0, w, h);
        ctx.strokeStyle = "rgba(14, 165, 233, 0.08)";
        ctx.lineWidth = 0.5;
        const step = 40;
        for (let i = 0; i < points.length; i++) {
          const p = points[i];
          p.vx += (p.ox - p.x) * 0.01 + (Math.random() - 0.5) * 0.3;
          p.vy += (p.oy - p.y) * 0.01 + (Math.random() - 0.5) * 0.3;
          p.vx *= 0.95; p.vy *= 0.95;
          p.x += p.vx; p.y += p.vy;
          const col = (i % Math.round(w / step));
          const row = Math.floor(i / Math.round(w / step));
          const right = i + 1;
          const down  = i + Math.round(w / step);
          if (right < points.length && (right % Math.round(w / step)) !== 0) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(points[right].x, points[right].y);
            ctx.stroke();
          }
          if (down < points.length) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(points[down].x, points[down].y);
            ctx.stroke();
          }
          ctx.fillStyle = "rgba(14, 165, 233, 0.25)";
          ctx.beginPath();
          ctx.arc(p.x, p.y, 1.2, 0, Math.PI * 2);
          ctx.fill();
        }
        requestAnimationFrame(draw);
      }
      window.addEventListener("resize", resize);
      resize();
      draw();
    })();
  </script>

  <!-- Real-time Price Fetcher -->
  <script>
    async function fetchPrice() {
      try {
        const res = await fetch('https://api.binance.com/api/v3/ticker/24hr?symbols=%5B%22BTCUSDT%22%2C%22ETHUSDT%22%5D', {
          headers: { 'Accept': 'application/json' },
          signal: AbortSignal.timeout(8000)
        });
        if (!res.ok) throw new Error('Binance API error: ' + res.status);
        const data = await res.json();
        const btc = data.find(d => d.symbol === 'BTCUSDT');
        const eth = data.find(d => d.symbol === 'ETHUSDT');
        updatePriceUI({ btc, eth });
      } catch (e) {
        console.warn('[Price] fetch error, retrying in 15s:', e.message);
        setTimeout(fetchPrice, 15000);
      }
    }

    function fmt(n) {
      if (n == null) return '--';
      const num = Number(n);
      return '$' + num.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
    function fmtChange(v) {
      if (v == null) return '--';
      const num = Number(v);
      const cls = num >= 0 ? 'text-green-400' : 'text-red-400';
      return '<span class="' + cls + '">' + (num >= 0 ? '+' : '') + num.toFixed(2) + '%</span>';
    }
    function fearColor(v) {
      if (v == null) return 'text-purple-400';
      if (v <= 25) return 'text-red-400';
      if (v <= 45) return 'text-orange-400';
      if (v <= 55) return 'text-amber-400';
      if (v <= 75) return 'text-green-400';
      return 'text-emerald-400';
    }

    function updatePriceUI({ btc, eth }) {
      const btcEl = document.getElementById('price-btc');
      const btcChg = document.getElementById('change-btc');
      if (btcEl && btc?.lastPrice != null) btcEl.textContent = fmt(btc.lastPrice);
      if (btcChg) btcChg.innerHTML = fmtChange(btc?.priceChangePercent);

      const ethEl = document.getElementById('price-eth');
      const ethChg = document.getElementById('change-eth');
      if (ethEl && eth?.lastPrice != null) ethEl.textContent = fmt(eth.lastPrice);
      if (ethChg) ethChg.innerHTML = fmtChange(eth?.priceChangePercent);
    }

    async function fetchFearGreed() {
      try {
        const res = await fetch('https://api.alternative.me/fng/?limit=1', {
          headers: { 'Accept': 'application/json' },
          signal: AbortSignal.timeout(8000)
        });
        if (!res.ok) return;
        const data = await res.json();
        const item = data?.data?.[0];
        if (!item) return;
        const fgEl = document.getElementById('price-fear');
        const fgLabel = document.getElementById('fear-label');
        if (fgEl) {
          const v = parseInt(item.value);
          fgEl.className = 'metric-value text-lg md:text-xl ' + fearColor(v);
          fgEl.textContent = v;
        }
        if (fgLabel) fgLabel.textContent = item.value_classification || '';
      } catch {}
    }

    fetchPrice();
    fetchFearGreed();
    setInterval(fetchPrice, 60000);
    setInterval(fetchFearGreed, 300000);
  </script>
</BaseLayout>
