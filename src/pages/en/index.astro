---
import BaseLayout from "../../layouts/BaseLayout.astro";
import fs from 'fs';
import path from 'path';

// 读取模拟盘数据，计算当前资金
const tradesPath = path.resolve('src/data/trades.json');
let trades = [];
try {
  trades = JSON.parse(fs.readFileSync(tradesPath, 'utf-8'));
} catch (e) {
  trades = [];
}
const totalPnl = trades.filter(t => t.status === 'closed').reduce((s, t) => s + (t.pnl || 0), 0);
const currentBalance = (1000000 + totalPnl).toLocaleString();

// 服务端获取市场数据（构建时预填）
let btcPrice = null, btcChange = null, ethPrice = null, ethChange = null, fearValue = null, fearLabel = '';
try {
  const priceRes = await fetch('https://api.binance.com/api/v3/ticker/24hr?symbols=%5B%22BTCUSDT%22%2C%22ETHUSDT%22%5D', { signal: AbortSignal.timeout(5000) });
  if (priceRes.ok) {
    const priceData = await priceRes.json();
    const btc = priceData.find(d => d.symbol === 'BTCUSDT');
    const eth = priceData.find(d => d.symbol === 'ETHUSDT');
    btcPrice = btc?.lastPrice ? Number(btc.lastPrice) : null;
    btcChange = btc?.priceChangePercent ? Number(btc.priceChangePercent) : null;
    ethPrice = eth?.lastPrice ? Number(eth.lastPrice) : null;
    ethChange = eth?.priceChangePercent ? Number(eth.priceChangePercent) : null;
  }
} catch {}
try {
  const fearRes = await fetch('https://api.alternative.me/fng/?limit=1', { signal: AbortSignal.timeout(5000) });
  if (fearRes.ok) {
    const fearData = await fearRes.json();
    const item = fearData?.data?.[0];
    if (item) {
      fearValue = parseInt(item.value);
      fearLabel = item.value_classification || '';
    }
  }
} catch {}

function fmtPrice(n) {
  if (n == null) return '--';
  return '$' + Number(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}
function fmtChange(v) {
  if (v == null) return '--';
  const num = Number(v);
  const cls = num >= 0 ? 'text-green-400' : 'text-red-400';
  return `<span class="${cls}">${num >= 0 ? '+' : ''}${num.toFixed(2)}%</span>`;
}
function fearColor(v) {
  if (v == null) return 'text-purple-400';
  if (v <= 25) return 'text-red-400';
  if (v <= 45) return 'text-orange-400';
  if (v <= 55) return 'text-amber-400';
  if (v <= 75) return 'text-green-400';
  return 'text-emerald-400';
}
