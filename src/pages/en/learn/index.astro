<BaseLayout title="Learning Center - 1H Crypto" lang="en" description="Learn crypto from scratch — 20+ original tutorials covering buying, trading, security, DeFi, and more." activeNav="learn">
<div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
  <p class="text-[var(--text-muted)] text-sm mb-2">
    <a href="/en/" class="text-primary hover:underline">← Back to Home</a>
  </p>

  <h1 class="text-3xl font-bold text-[var(--text-primary)] mb-2">Learning Center</h1>
  <p class="text-[var(--text-secondary)] mb-10">Start from zero. Systematic crypto education. All articles original and regularly updated.</p>

  <!-- Basics -->
  <section class="mb-12">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-4 flex items-center gap-2">
      <span class="w-1.5 h-6 bg-primary rounded-full inline-block"></span>
      Basics
    </h2>
    <div class="grid md:grid-cols-2 gap-4">
      <a href="/en/learn/what-is-bitcoin" class="block p-5 rounded-xl bg-[var(--bg-secondary)] border border-[var(--border-color)] hover:border-primary/50 transition-colors group">
        <h3 class="text-lg font-bold text-[var(--text-primary)] group-hover:text-primary transition-colors">What is Bitcoin?</h3>
        <p class="text-[var(--text-muted)] text-sm mt-1">A no-nonsense explanation for beginners</p>
      </a>
      <a href="/en/learn/what-is-blockchain" class="block p-5 rounded-xl bg-[var(--bg-secondary)] border border-[var(--border-color)] hover:border-primary/50 transition-colors group">
