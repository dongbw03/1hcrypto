        <p class="text-[var(--text-muted)] text-sm mt-1">No buzzwords version</p>
      </a>
      <a href="/en/learn/what-is-ethereum" class="block p-5 rounded-xl bg-[var(--bg-secondary)] border border-[var(--border-color)] hover:border-primary/50 transition-colors group">
        <h3 class="text-lg font-bold text-[var(--text-primary)] group-hover:text-primary transition-colors">What is Ethereum?</h3>
        <p class="text-[var(--text-muted)] text-sm mt-1">More than just "Bitcoin 2.0"</p>
      </a>
      <a href="/en/learn/what-is-nft" class="block p-5 rounded-xl bg-[var(--bg-secondary)] border border-[var(--border-color)] hover:border-primary/50 transition-colors group">
