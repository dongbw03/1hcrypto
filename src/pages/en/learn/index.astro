      </a>
      <a href="/en/learn/dca-strategy-en" class="block p-5 rounded-xl bg-[var(--bg-secondary)] border border-[var(--border-color)] hover:border-primary/50 transition-colors group">
        <h3 class="text-lg font-bold text-[var(--text-primary)] group-hover:text-primary transition-colors">DCA Strategy</h3>
        <p class="text-[var(--text-muted)] text-sm mt-1">The most reliable way to build a position.</p>
      </a>
    </div>
  </section>

  <!-- Evergreen (Timeless) -->
  <section class="mb-12">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-4 flex items-center gap-2">
      <span class="w-1.5 h-6 bg-amber-500 rounded-full inline-block"></span>
      Evergreen (Timeless)
    </h2>
    <div class="grid md:grid-cols-2 gap-4">
      <a href="/en/learn/crypto-tax-guide" class="block p-5 rounded-xl bg-[var(--bg-secondary)] border border-[var(--border-color)] hover:border-primary/50 transition-colors group">
        <h3 class="text-lg font-bold text-[var(--text-primary)] group-hover:text-primary transition-colors">Crypto Tax Guide 2026</h3>
        <p class="text-[var(--text-muted)] text-sm mt-1">What every trader needs to know about taxable events.</p>
      </a>
      <a href="/en/learn/cross-exchange-hedge" class="block p-5 rounded-xl bg-[var(--bg-secondary)] border border-[var(--border-color)] hover:border-primary/50 transition-colors group">
