    "@type": "Person",
    "name": "1H Crypto Trader"
  },
  "publisher": {
    "@type": "Organization",
    "name": "1H Crypto",
    "logo": {
      "@type": "ImageObject",
      "url": "https://1hcrypto.com/favicon.svg"
