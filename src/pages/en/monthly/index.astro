---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Monthly Deep Dive" lang="en">

<div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
  <h1 class="text-3xl font-bold text-white mb-2">Monthly Deep Dive</h1>
  <p class="text-[var(--text-muted)] mb-8">First week of each month: strategy backtest data + classic case analysis + seasonal patterns.</p>
  <div class="card p-8 text-center">
    <p class="text-sm text-[var(--text-muted)] max-w-md mx-auto">First monthly deep dive will be published after a full month of daily analysis.</p>
  </div>
</div>

</BaseLayout>
