---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Dynamically read English news Markdown files
const newsFiles = await import.meta.glob("../../content/en/news/*.md", { eager: true });

// Parse all news articles
const articles = Object.entries(newsFiles).map(([filePath, module]) => {
  const slug = filePath.split("/").pop().replace(".md", "");
  const data = module.frontmatter || {};
  return {
    slug,
    title: data.title || "Untitled",
    date: data.date || new Date().toISOString(),
    source: data.source || "",
    url: data.url || "",
    sentiment: data.sentiment || "Neutral",
    coins: data.coins || [],
    importance: data.importance || "Low",
    tags: data.tags || [],
    draft: data.draft || false,
    analystView: data.analyst_view || "",
    marketImpact: data.market_impact || "",
    content: module.compiledContent ? module.compiledContent() : "",
  };
}).filter(article => !article.draft)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Sentiment color mapping
const sentimentColor = {
  "Bullish": "text-green-400 bg-green-500/10 border-green-500/30",
  "Bearish": "text-red-400 bg-red-500/10 border-red-500/30",
  "Neutral": "text-yellow-400 bg-yellow-500/10 border-yellow-500/30",
};

const importanceColor = {
  "High": "border-l-red-500",
  "Medium": "border-l-yellow-500",
  "Low": "border-l-green-500",
};
---


  <script type="application/ld+json" set:html={`{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Crypto News | Daily Market Headlines | 1H Crypto",
  "description": "Daily crypto market news: BTC ETF flows, regulatory updates, macro data.",
  "image": {
    "@type": "ImageObject",
    "url": "https://1hcrypto.com/og-default.png",
    "width": 1200,
    "height": 630
  },
  "datePublished": "2026-05-31T16:20:03+08:00",
  "dateModified": "2026-05-31T16:20:03+08:00",
  "author": {
    "@type": "Person",
    "name": "1H Crypto Trader"
  },
  "publisher": {
    "@type": "Organization",
    "name": "1H Crypto",
    "logo": {
      "@type": "ImageObject",
      "url": "https://1hcrypto.com/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "@id",
    "@id": "https://1hcrypto.com/en/news/"
  }
}`}></script>
<BaseLayout 
  title="Crypto News | Daily Market Headlines | 1H Crypto" 
  description="Daily crypto market news: BTC ETF flows, regulatory updates, macro data." 
  lang="en" 
  activeNav="news"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <div class="section-header-nonflex mb-8 fade-in-on-scroll">
      <h1 class="text-3xl font-bold text-white mb-2">📰 Crypto News</h1>
      <p class="text-[var(--text-muted)]">Daily market headlines · Data-driven · No noise</p>
    </div>

    <!-- News list -->
    {articles.length > 0 ? (
      <div class="space-y-5 fade-in-on-scroll">
        {articles.map((article, idx) => (
          <div class={`card p-5 border-l-4 ${importanceColor[article.importance] || "border-l-gray-500"} hover:border-[var(--primary)]/50 transition-colors fade-in-on-scroll`} style={`animation-delay: ${idx * 0.08}s`}>
            <!-- Top bar: sentiment + date + importance -->
            <div class="flex flex-wrap items-center gap-2 mb-3">
              <span class={`text-xs font-bold px-2 py-0.5 rounded ${sentimentColor[article.sentiment] || "text-gray-400 bg-gray-500/10"}`}>
                {article.sentiment}
              </span>
              <span class="text-[var(--text-muted)] text-xs">{new Date(article.date).toLocaleDateString('en-US')}</span>
              {article.importance === "High" && (
                <span class="badge badge-red">Important</span>
              )}
            </div>

            <!-- Title -->
            <h3 class="text-white font-semibold text-lg mb-2 hover:text-[var(--primary)] transition-colors">
              <a href={`/en/news/${article.slug}`} class="no-underline">{article.title}</a>
            </h3>

            <!-- Coin tags -->
            {article.coins.length > 0 && (
              <div class="flex flex-wrap gap-1 mb-3">
                {article.coins.map(coin => (
                  <span class="text-xs px-1.5 py-0.5 rounded bg-[var(--bg-card)] text-primary font-mono border border-[var(--border)]">{coin}</span>
                ))}
              </div>
            )}

            <!-- AI Summary -->
            {article.content && (
              <p class="text-sm text-[var(--text-secondary)] line-clamp-2 mb-3 leading-relaxed">{article.content.replace(/<[^>]+>/g, '').substring(0, 120)}...</p>
            )}

            <!-- Bull/Bear judgment (core value) -->
            {article.sentiment && (
              <div class={`mt-3 p-3 rounded-lg border-l-2 ${sentimentColor[article.sentiment] || "border-gray-500/30"}`}>
                <div class="flex items-center gap-1.5 mb-1">
                  <span class="text-xs font-bold">{article.sentiment === "Bullish" ? "📈 Bullish" : article.sentiment === "Bearish" ? "📉 Bearish" : "⚖️ Neutral"}</span>
                </div>
                {article.marketImpact && (
                  <p class="text-xs text-[var(--text-secondary)] leading-relaxed">{article.marketImpact}</p>
                )}
              </div>
            )}

            <!-- Read full article -->
            <a href={`/en/news/${article.slug}`} class="text-xs text-[var(--primary)] hover:underline mt-2 inline-block no-underline">
              Read Full Article →
            </a>
          </div>
        ))}
      </div>
    ) : (
      <div class="card p-8 text-center fade-in-on-scroll">
        <p class="text-[var(--text-muted)] mb-4">No news data yet</p>
        <p class="text-xs text-[var(--text-muted)]">Auto news system running, please refresh later</p>
      </div>
    )}

  </div>

  <!-- Disclaimer -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pb-12">
    <div class="p-4 bg-[var(--bg-card)]/50 border border-[var(--border)] rounded-lg text-xs text-[var(--text-muted)]">
      <strong class="text-[var(--text-secondary)]">⚠️ Disclaimer:</strong> News compiled from public sources for informational purposes only. Not investment advice.
    </div>
  </div>

    <!-- ====== Support Banner ====== -->
    <div class="mt-8 max-w-4xl mx-auto px-4 sm:px-6"><div class="px-5 py-3 bg-[var(--bg-card)]/30 border border-[var(--border)] rounded-lg text-xs text-[var(--text-muted)] text-center"><span class="text-[var(--text-secondary)] font-medium">🛠 Support us:</span> Sign up via <a href="https://www.okx.com/join/1HCRYPTO" target="_blank" rel="sponsored" class="text-primary hover:underline">OKX (code: 1HCRYPTO)</a> or <a href="https://accounts.binance.com/register?ref=CPA_00ZIV33RO4" target="_blank" rel="sponsored" class="text-accent hover:underline">Binance (code: CPA_00ZIV33RO4)</a> — no extra cost, we earn commission.</div></div>
</BaseLayout>
