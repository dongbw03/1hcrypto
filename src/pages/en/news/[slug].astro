---
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const newsFiles = await import.meta.glob("../../../content/en/news/*.md", { eager: true });
  const paths = Object.entries(newsFiles).map(([filePath, module]) => {
    const slug = filePath.split("/").pop().replace(".md", "");
    return {
      params: { slug },
      props: { module },
    };
  });
  return paths;
}

const { module } = Astro.props;
const data = module.frontmatter || {};
const content = module.compiledContent ? module.compiledContent() : "";

const title = data.title || "Untitled";
const date = data.date || new Date().toISOString();
const sentiment = data.sentiment || "Neutral";
const coins = data.coins || [];
const importance = data.importance || "Low";
const source = data.source || "";
const originalUrl = data.url || "";
const analystView = data.analyst_view || "";
const marketImpact = data.market_impact || "";

const fmtDate = new Date(date).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' });
const sentimentColor =
  sentiment === "Bullish" ? "text-green-400 bg-green-500/10 border-green-500/30"
  : sentiment === "Bearish" ? "text-red-400 bg-red-500/10 border-red-500/30"
  : "text-yellow-400 bg-yellow-500/10 border-yellow-500/30";
const importanceBorder =
  importance === "High" ? "border-l-red-500"
  : importance === "Medium" ? "border-l-yellow-500"
  : "border-l-green-500";
---
<script type="application/ld+json" set:html={`{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "${title.replace(/"/g, '\\"')} | 1H Crypto",
  "description": "${analystView.replace(/"/g, '\\"').substring(0,160)}",
  "datePublished": "${new Date(date).toISOString()}",
  "dateModified": "${new Date(date).toISOString()}",
  "author": { "@type": "Person", "name": "1H Crypto" },
  "publisher": { "@type": "Organization", "name": "1H Crypto", "logo": { "@type": "ImageObject", "url": "https://1hcrypto.com/favicon.svg" } },
  "mainEntityOfPage": { "@type": "@id", "@id": "https://1hcrypto.com/en/news/${Astro.params.slug}/" }
}`}></script>

<BaseLayout
  title={`${title} | Crypto News | 1H Crypto`}
  description={`${title} — AI summary with bull/bear judgment.`}
  lang="en"
  activeNav="news"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <!-- Back -->
    <a href="/en/news/" class="inline-flex items-center gap-1 text-sm text-[var(--text-muted)] hover:text-primary transition-colors no-underline mb-6">
      ← Back to News
    </a>

    <!-- Article Header -->
    <div class={`card p-6 mb-6 border-l-4 ${importanceBorder}`}>
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class={`text-xs font-bold px-2 py-0.5 rounded ${sentimentColor}`}>{sentiment}</span>
        <span class="text-[var(--text-muted)] text-xs">{fmtDate}</span>
        {importance === "High" && <span class="badge badge-red">Important</span>}
      </div>
      <h1 class="text-2xl font-bold text-white mb-3 leading-tight">{title}</h1>
      {coins && coins.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {coins.map(coin => (
            <span class="text-xs px-2 py-0.5 rounded bg-[var(--bg-card)] text-primary font-mono border border-[var(--border)]">{coin}</span>
          ))}
        </div>
      )}
    </div>

    <!-- Original Link -->
    {originalUrl && (
      <div class="mb-4 text-xs">
        <a href={originalUrl} target="_blank" rel="noopener" class="text-primary hover:underline">Read Original Article ↗</a>
      </div>
    )}

    <!-- Article Body -->
    <div class="card p-6 md:p-8">
      <article class="prose prose-invert prose-sm max-w-none
        prose-p:text-[var(--text-secondary)] prose-p:leading-relaxed prose-p:mb-4
        prose-h2:text-white prose-h2:text-lg prose-h2:font-bold prose-h2:mt-6 prose-h2:mb-3 prose-h2:pb-2 prose-h2:border-b prose-h2:border-[var(--border)]
        prose-h3:text-white prose-h3:text-base prose-h3:font-semibold prose-h3:mt-4 prose-h3:mb-2
        prose-strong:text-white
        prose-blockquote:border-l-primary prose-blockquote:bg-[var(--primary)]/5 prose-blockquote:rounded-r-lg prose-blockquote:py-3 prose-blockquote:px-4 prose-blockquote:my-4 prose-blockquote:text-[var(--text-secondary)]
        prose-code:text-primary prose-code:bg-[var(--bg-card)] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-xs
        prose-ul:pl-5 prose-li:text-[var(--text-secondary)] prose-li:mb-1
        prose-ol:pl-5
      ">
        <Fragment set:html={content} />
      </article>
    </div>

    <!-- Bull/Bear Judgment (emphasized at end) -->
    <div class={`mt-6 card p-4 border-l-4 ${importanceBorder} bg-[var(--bg-card)]/50`}>
      <div class="flex items-center gap-2 mb-1">
        <span class={`text-sm font-bold ${sentiment === "Bullish" ? "text-green-400" : sentiment === "Bearish" ? "text-red-400" : "text-yellow-400"}`}>
          {sentiment === "Bullish" ? "📈 Bullish View" : sentiment === "Bearish" ? "📉 Bearish View" : "⚖️ Neutral View"}
        </span>
      </div>
      {analystView && (
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed mt-1">{analystView}</p>
      )}
      {marketImpact && (
        <div class="mt-3 p-3 bg-[var(--bg-primary)]/50 rounded-lg border border-[var(--border)]">
          <p class="text-xs text-[var(--text-muted)] leading-relaxed"><strong class="text-[var(--text-secondary)]">Market Impact:</strong> {marketImpact}</p>
        </div>
      )}
    </div>

    <!-- Disclaimer -->
    <div class="mt-8 p-4 bg-[var(--bg-card)]/50 border border-[var(--border)] rounded-lg text-xs text-[var(--text-muted)]">
      <strong class="text-[var(--text-secondary)]">⚠️ Disclaimer:</strong> News compiled from public sources for informational purposes only. Not investment advice.
    </div>
  </div>
</BaseLayout>
