---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Recommended - 1H Crypto" lang="en">

<div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
  <h1 class="text-3xl font-bold text-white mb-2">Recommended</h1>
  <p class="text-[var(--text-muted)] mb-8">
    These are the tools and services I genuinely use in my daily analysis. Some links are affiliate links — using them may earn me a commission at no extra cost to you.
  </p>

  <div class="space-y-4">
    <div class="card p-5">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1">
          <h3 class="text-white font-semibold mb-1">Binance</h3>
          <p class="text-sm text-[var(--text-muted)] leading-relaxed">
            The world's largest crypto exchange. Deep BTC & ETH liquidity, full suite of spot/derivatives products, and excellent sub-account management.
          </p>
        </div>
        <a href="#" class="shrink-0 px-4 py-2 bg-primary hover:bg-primary/90 text-white font-medium rounded-lg transition-colors text-sm whitespace-nowrap">Sign Up →</a>
      </div>
    </div>

    <div class="card p-5">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1">
          <h3 class="text-white font-semibold mb-1">OKX</h3>
          <p class="text-sm text-[var(--text-muted)] leading-relaxed">
            Best user experience for Chinese traders. Smooth web and mobile apps, transparent funding rate data, and responsive Chinese customer support.
          </p>
        </div>
        <a href="#" class="shrink-0 px-4 py-2 bg-primary hover:bg-primary/90 text-white font-medium rounded-lg transition-colors text-sm whitespace-nowrap">Sign Up →</a>
      </div>
    </div>

    <div class="card p-5">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1">
          <h3 class="text-white font-semibold mb-1">Bybit</h3>
          <p class="text-sm text-[var(--text-muted)] leading-relaxed">
            Top choice for derivatives trading. Intuitive UI, complete historical funding rate data, well-suited for price action traders.
          </p>
        </div>
        <a href="#" class="shrink-0 px-4 py-2 bg-primary hover:bg-primary/90 text-white font-medium rounded-lg transition-colors text-sm whitespace-nowrap">Sign Up →</a>
      </div>
    </div>

    <div class="card p-5">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1">
          <h3 class="text-white font-semibold mb-1">TradingView</h3>
          <p class="text-sm text-[var(--text-muted)] leading-relaxed">
            All chart analysis is done on TradingView. Bar labeling, multi-timeframe switching, custom scripting — the best tool for price action analysis.
          </p>
        </div>
        <a href="#" class="shrink-0 px-4 py-2 bg-primary hover:bg-primary/90 text-white font-medium rounded-lg transition-colors text-sm whitespace-nowrap">Try →</a>
      </div>
    </div>

    <div class="card p-5">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1">
          <h3 class="text-white font-semibold mb-1">Coinglass</h3>
          <p class="text-sm text-[var(--text-muted)] leading-relaxed">
            Go-to for derivatives data. Funding rates, open interest, long/short ratios, liquidation heatmaps — all in one place.
          </p>
        </div>
        <a href="#" class="shrink-0 px-4 py-2 bg-primary hover:bg-primary/90 text-white font-medium rounded-lg transition-colors text-sm whitespace-nowrap">Use →</a>
      </div>
    </div>

    <div class="card p-5">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1">
          <h3 class="text-white font-semibold mb-1">Ledger</h3>
          <p class="text-sm text-[var(--text-muted)] leading-relaxed">
            Hardware wallet. Long-term BTC & ETH holdings are stored here. Security first.
          </p>
        </div>
        <a href="#" class="shrink-0 px-4 py-2 bg-primary hover:bg-primary/90 text-white font-medium rounded-lg transition-colors text-sm whitespace-nowrap">Buy →</a>
      </div>
    </div>

    <div class="card p-5">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1">
          <h3 class="text-white font-semibold mb-1">3Commas</h3>
          <p class="text-sm text-[var(--text-muted)] leading-relaxed">
            Quantitative trading tool. Useful for strategy backtesting and signal management. Best for users with some programming background.
          </p>
        </div>
        <a href="#" class="shrink-0 px-4 py-2 bg-primary hover:bg-primary/90 text-white font-medium rounded-lg transition-colors text-sm whitespace-nowrap">Sign Up →</a>
      </div>
    </div>

    <div class="card p-5">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1">
          <h3 class="text-white font-semibold mb-1">CryptoQuant</h3>
          <p class="text-sm text-[var(--text-muted)] leading-relaxed">
            On-chain data platform. Exchange flows, holder distribution, miner behavior — all the on-chain signals in one dashboard.
          </p>
        </div>
        <a href="#" class="shrink-0 px-4 py-2 bg-primary hover:bg-primary/90 text-white font-medium rounded-lg transition-colors text-sm whitespace-nowrap">Use →</a>
      </div>
    </div>
  </div>

  <div class="mt-8 p-4 bg-amber-600/10 border border-amber-600/20 rounded-lg">
    <p class="text-sm text-amber-300">
      <strong>Disclaimer:</strong> Some links are affiliate links. Using them may earn me a commission at no extra cost to you. See <a href="/en/disclosure/" class="text-amber-400 underline">Affiliate Disclosure</a>.
    </p>
  </div>
</div>

</BaseLayout>
