---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Paper Trading Tracker - $1M Virtual" lang="en">

<div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
  <h1 class="text-3xl font-bold text-white mb-2">Paper Trading Tracker</h1>
  <p class="text-[var(--text-muted)] mb-8">Starting capital: $1,000,000 USDT (virtual). Assets: BTC & ETH. Timeframe: 1H candles. Strategy: Al Brooks Price Action.</p>
  <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-8">
    <div class="card p-4 text-center"><div class="text-xs text-[var(--text-muted)] mb-1">Starting Capital</div><div class="text-lg font-bold text-white font-mono">1,000,000</div></div>
    <div class="card p-4 text-center"><div class="text-xs text-[var(--text-muted)] mb-1">Current NAV</div><div class="text-lg font-bold text-white font-mono">--</div></div>
    <div class="card p-4 text-center"><div class="text-xs text-[var(--text-muted)] mb-1">Win Rate</div><div class="text-lg font-bold text-green-400 font-mono">--</div></div>
    <div class="card p-4 text-center"><div class="text-xs text-[var(--text-muted)] mb-1">Max Drawdown</div><div class="text-lg font-bold text-red-400 font-mono">--</div></div>
    <div class="card p-4 text-center"><div class="text-xs text-[var(--text-muted)] mb-1">Profit Factor</div><div class="text-lg font-bold text-amber-400 font-mono">--</div></div>
  </div>
  <div class="card p-8 text-center"><p class="text-sm text-[var(--text-muted)] max-w-md mx-auto">Daily trade records will be published alongside the daily analysis.</p></div>
</div>

</BaseLayout>
