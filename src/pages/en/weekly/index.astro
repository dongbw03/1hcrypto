---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Weekly Review" lang="en">

<div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
  <h1 class="text-3xl font-bold text-white mb-2">Weekly Review</h1>
  <p class="text-[var(--text-muted)] mb-8">Every Sunday: weekly prediction review + paper trading performance + next week key structures.</p>
  <div class="card p-8 text-center">
    <p class="text-sm text-[var(--text-muted)] max-w-md mx-auto">First weekly review will be published after a full week of daily analysis.</p>
  </div>
</div>

</BaseLayout>
