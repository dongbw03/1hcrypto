---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Weekly Review | 1H Crypto" description="Every Bitcoin & EthereumPrice Action Review，Weekly TA based on Al Brooks Technical Analysis Summary。" lang="en" activeNav="weekly">
<script type="application/ld+json">{JSON.stringify({
 "@context": "https://schema.org",
 "@type": "Article",
 "headline": "Weekly Review",
 "description": "Every Bitcoin & EthereumPrice Action Review，Weekly TA based on Al Brooks Technical Analysis Summary。",
 "inLanguage": "zh-CN",
 "datePublished": "2026-01-05T08:00:00+08:00",
 "dateModified": new Date().toISOString(),
 "author": {
 "@type": "Person",
 "name": "1H Crypto Trader"
 },
 "publisher": {
 "@type": "Organization",
 "name": "1H Crypto",
 "logo": {
 "@type": "ImageObject",
 "url": "https://1hcrypto.com/favicon.svg"
 }
 },
 "mainEntityOfPage": {
 "@type": "@id",
 "@id": "https://1hcrypto.com/zh/weekly/"
 }
})}</script>

<div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
 <!-- Header -->
 <div class="mb-10">
 <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">Weekly Review</h1>
 <p class="text-[var(--text-muted)] text-sm">Published every Sunday · on <span class="text-primary">Al Brooks Price Action</span> BTC & ETH Weekly Technical Analysis</p>
 <div class="mt-4 flex items-center gap-3 text-xs text-[var(--text-muted)]">
 <span class="px-2.5 py-1 rounded-full bg-white/5 border border-[var(--border)]">Every updated 20:00</span>
 <span>|</span>
 <span>Trading Calendar：Monday to Friday</span>
 </div>
 </div>

 
 <div class="mb-12">
 <div class="flex items-center gap-2 mb-6">
 <div class="w-1 h-5 rounded-full bg-primary"></div>
 <h2 class="text-xl font-bold text-white">Latest Review</h2>
 <span class="text-xs text-[var(--text-muted)] ml-2">2026-06-02 starting from</span>
 </div>

 <div class="card p-8 text-center">
 <div class="text-4xl mb-4">📊</div>
 <h3 class="text-lg font-bold text-white mb-2">Weekly Review in preparation</h3>
 <p class="text-sm text-[var(--text-muted)] mb-4">Paper trading will 2026-06-02 Officially Launched，First Weekly Review goes live 2026-06-07。</p>
 <div class="flex flex-wrap justify-center gap-3 text-xs text-[var(--text-muted)]">
 <span class="px-3 py-1.5 rounded-full bg-white/5 border border-[var(--border)]">Every updated 20:00</span>
 <span class="px-3 py-1.5 rounded-full bg-white/5 border border-[var(--border)]"> on Al Brooks Price Action</span>
 <span class="px-3 py-1.5 rounded-full bg-white/5 border border-[var(--border)]"> P&L Transparent display</span>
 </div>
 <a href="/zh/daily/" class="inline-flex items-center gap-1.5 text-sm text-primary hover:underline mt-6"> Daily Analysis →</a>
 </div>
 </div>

 
 <div class="mb-8">
 <div class="flex items-center gap-2 mb-6">
 <div class="w-1 h-5 rounded-full bg-[var(--border)]"></div>
 <h2 class="text-xl font-bold text-white">Historical Review</h2>
 </div>

 <div class="card p-6 text-center">
 <p class="text-sm text-[var(--text-muted)]">No history yet。 Weekly Review on 2026-06-07 。</p>
 </div>
 </div>

 <!-- Weekly Methodology -->
 <div class="card p-6 bg-white/[0.02] border border-[var(--border)]">
 <h3 class="text-sm font-semibold text-white mb-3">Weekly Review </h3>
 <ul class="space-y-2 text-sm text-[var(--text-muted)]">
 <li class="flex items-start gap-2"><span class="text-primary mt-0.5">▸</span> on Al Brooks Price Action，Focusing on 1H/4H K Structure</li>
 <li class="flex items-start gap-2"><span class="text-primary mt-0.5">▸</span>Every Summary of paper trading records，P&L Transparent display</li>
 <li class="flex items-start gap-2"><span class="text-primary mt-0.5">▸</span>CombiningOn-Chain Snapshot（Exchange Net Outflow/FlowIn）Auxiliary Analysis</li>
 <li class="flex items-start gap-2"><span class="text-primary mt-0.5">▸</span>Next Week Plan：Key + Trigger Conditions + Risk Management</li>
 </ul>
 </div>
</div>

</BaseLayout>
