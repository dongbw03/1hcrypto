---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import matter from 'gray-matter';

const analysisFiles = await import.meta.glob('../../../content/zh/analysis/*.md', { eager: true });

const analysisPosts = Object.entries(analysisFiles)
  .map(([filePath, module]) => {
    try {
      const data = module.frontmatter || {};
      const filename = filePath.split('/').pop().replace('.md', '');
      const slug = filename.replace(/^\d{4}-\d{2}-\d{2}-\d{2}-\d{2}-/, '');
      return {
        slug,
        title: data.title || filename,
        date: String(data.date || ''),
        description: data.description || '',
        tags: data.tags || [],
        signal: data.signal || '中性',
        importance: data.importance || '低',
      };
    } catch (e) {
      return null;
    }
  })
  .filter(p => p !== null)
  .sort((a, b) => String(b.date).localeCompare(String(a.date)));

const fmtDate = (d) => {
  try { return new Date(d).toLocaleDateString('zh-CN', { year:'numeric', month:'long', day:'numeric' }); } catch(e) { return d; }
};
const signalBadge = (s) => {
  if (s === '看多') return 'bg-green-500/10 text-green-400 border-green-500/30';
  if (s === '看空') return 'bg-red-500/10 text-red-400 border-red-500/30';
  return 'bg-yellow-500/10 text-yellow-400 border-yellow-500/30';
};
const importanceBorder = (imp) => {
  if (imp === '高') return 'border-l-red-500';
  if (imp === '中') return 'border-l-yellow-500';
  return 'border-l-green-500';
};
const isNew = (d) => {
  try { return (Date.now() - new Date(d).getTime()) < 3 * 24 * 60 * 60 * 1000; } catch(e) { return false; }
};
---
<script type="application/ld+json" set:html={`{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "价格分析 - 1H币研",
  "description": "BTC & ETH 专业技术分析报告（基于 1 小时线）",
  "datePublished": "2026-06-02T10:00:00+08:00",
  "author": { "@type": "Person", "name": "1H Crypto Trader" },
  "publisher": { "@type": "Organization", "name": "1H币研" }
}`}></script>

<BaseLayout title="价格分析 - 1H币研" description="BTC & ETH 专业技术分析报告（基于 1 小时线）" lang="zh" activeNav="analysis">
  <div class="max-w-[1400px] mx-auto lg:pl-10 lg:pr-2 px-4 py-12">
    <!-- 页面标题区 -->
    <div class="mb-12">
      <a href="/zh/" class="inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-blue-400 transition-colors mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        首页
      </a>
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-xl">📊</div>
        <div>
          <h1 class="text-2xl md:text-3xl font-bold text-white tracking-tight">价格分析</h1>
          <p class="text-gray-400 text-sm mt-0.5">BTC & ETH 专业技术分析 · 基于 Al Brooks 价格行为学</p>
        </div>
      </div>
      <div class="flex items-center gap-4 mt-4 text-xs text-gray-500">
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          {analysisPosts.length} 篇分析报告
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          每小时更新
        </span>
      </div>
    </div>

    {analysisPosts.length === 0 && (
      <div class="text-center py-20">
        <div class="text-5xl mb-4">📭</div>
        <p class="text-gray-400 text-lg">暂无分析报告</p>
        <p class="text-gray-500 text-sm mt-2">下次价格更新后将自动生成分析</p>
      </div>
    )}

    <!-- 文章列表 -->
    <div class="space-y-5">
      {analysisPosts.map((post) => (
        <a href={`/zh/analysis/${post.slug}/`} class={`group block relative bg-[#0d1117] border border-white/10 rounded-2xl p-6 hover:border-blue-500/30 transition-all duration-300 hover:shadow-lg hover:shadow-blue-500/5 hover:-translate-y-0.5 ${isNew(post.date) ? 'ring-1 ring-green-500/30' : ''}`}>
          {isNew(post.date) && (
            <div class="absolute -top-2 -right-2 px-2 py-0.5 text-[10px] font-bold bg-green-500 text-white rounded-full shadow-lg">NEW</div>
          )}
          <div class="flex flex-col sm:flex-row sm:items-start gap-4">
            <div class={`hidden sm:block w-1.5 self-stretch rounded-full ${post.signal === '看多' ? 'bg-green-500' : post.signal === '看空' ? 'bg-red-500' : 'bg-yellow-500'} opacity-60 flex-shrink-0`}></div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-medium border ${signalBadge(post.signal)}`}>
                  <span class={`inline-block w-1.5 h-1.5 rounded-full ${post.signal === '看多' ? 'bg-green-400' : post.signal === '看空' ? 'bg-red-400' : 'bg-yellow-400'}`}></span>
                  {post.signal}
                </span>
                {post.tags.slice(0, 3).map((tag) => (
                  <span class="text-[11px] px-2 py-0.5 rounded-full bg-white/5 text-gray-400 border border-white/10">{tag}</span>
                ))}
              </div>
              <h2 class="text-lg md:text-xl font-bold text-white group-hover:text-blue-400 transition-colors leading-snug mb-2">
                {post.title}
              </h2>
              {post.description && (
                <p class="text-sm text-gray-400 leading-relaxed mb-3 line-clamp-2">{post.description}</p>
              )}
              <div class="flex items-center gap-4 text-xs text-gray-500">
                <time datetime={post.date} class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  {fmtDate(post.date)}
                </time>
                <span class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  约 {Math.max(1, Math.ceil((post.description || '').length / 80))} 分钟阅读
                </span>
                <span class={`px-1.5 py-0.5 rounded text-[10px] font-medium border-l-2 ${importanceBorder(post.importance)}`}>
                  {post.importance}优先级
                </span>
              </div>
            </div>
            <div class="hidden sm:flex items-center flex-shrink-0">
              <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center group-hover:bg-blue-500/20 group-hover:text-blue-400 text-gray-600 transition-all duration-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
