---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import matter from 'gray-matter';
import { readFileSync } from 'fs';

const raw = readFileSync('src/content/zh/daily/2026-06-02.md', 'utf-8');
const { data, content } = matter(raw);
---

<BaseLayout title={`${data.title} - 每日研判 | 1H币研`} description={data.description} lang="zh" activeNav="daily">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": data.title,
    "description": data.description,
    "datePublished": "2026-06-02T08:00:00+08:00",
    "author": {"@type": "Person", "name": "1H Crypto Trader"},
    "publisher": {"@type": "Organization", "name": "1H币研"}
  })}></script>

  <div class="max-w-[1400px] mx-auto lg:pl-10 lg:pr-1 px-4 py-8 lg:py-12">
    <div class="lg:flex lg:gap-12">
      <article class="min-w-0">
        <header class="mb-12">
          <div class="flex items-center gap-2 mb-2">
            <span class={`badge badge-${data.sentiment === '偏多' ? 'green' : data.sentiment === '偏空' ? 'red' : 'blue'}`}>{data.sentiment}</span>
            <span class="text-xs text-[var(--text-muted)] font-mono">2026-06-02 08:00</span>
            <span class="text-xs text-[var(--text-muted)] ml-auto">1H</span>
          </div>
          <h1 class="text-xl md:text-2xl lg:text-[1.65rem] font-bold text-white leading-[1.35] mb-5 tracking-tight">{data.title}</h1>
          <div class="flex items-center gap-4 text-xs text-[var(--text-muted)]">
            <span>📊 市场结构</span>
            <span>🎯 核心判断</span>
            <span>📈 入场参考</span>
          </div>
        </header>

        <div class="article-content" set:html={content} />
      </article>

      <aside class="hidden lg:block w-48 flex-shrink-0">
        <div class="sticky top-24 bg-[var(--card)] border border-[var(--border)] rounded-xl p-5">
          <h3 class="text-sm font-bold text-white mb-4">📋 目录</h3>
          <nav class="toc-nav text-sm space-y-2" id="toc-nav">
            <a href="#btc-market-structure" class="block py-1 text-[var(--text-muted)] hover:text-primary transition-colors">BTC 市场结构</a>
            <a href="#btc-core-judgment" class="block py-1 text-[var(--text-muted)] hover:text-primary transition-colors">BTC 核心判断</a>
            <a href="#btc-key-levels" class="block py-1 text-[var(--text-muted)] hover:text-primary transition-colors">BTC 关键水平</a>
            <a href="#eth-market-structure" class="block py-1 text-[var(--text-muted)] hover:text-primary transition-colors">ETH 市场结构</a>
            <a href="#eth-core-judgment" class="block py-1 text-[var(--text-muted)] hover:text-primary transition-colors">ETH 核心判断</a>
          </nav>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .article-content {
    color: #c9cdd4;
    font-size: 1.05rem;
    line-height: 1.9;
    max-width: 1080px;
    font-variant-numeric: tabular-nums;
    -webkit-font-smoothing: antialiased;
  }
  .article-content h2 {
    font-size: 1.4rem;
    font-weight: 700;
    color: #e8e8e8;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-left: 1rem;
    border-left: 3px solid #4b9cf5;
    line-height: 1.45;
  }
  .article-content h3 {
    font-size: 1.15rem;
    font-weight: 600;
    color: #d8d8d8;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .article-content p {
    margin-bottom: 1.4rem;
    color: #c9cdd4;
  }
  .article-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.93rem;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.07);
  }
  .article-content th {
    background: rgba(255,255,255,0.04);
    padding: 0.7rem 1rem;
    text-align: left;
    font-size: 0.83rem;
    font-weight: 600;
    color: #d0d0d0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .article-content td {
    padding: 0.65rem 1rem;
    font-size: 0.88rem;
    color: #8b949e;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .article-content hr {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.12), transparent);
    margin: 2.5rem 0;
  }
</style>
