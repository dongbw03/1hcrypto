---
import BaseLayout from "../../../layouts/BaseLayout.astro";
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "每日研判 - BTC & ETH 小时图价格行为分析",
  "description": "BTC/USDT & ETH/USDT 小时图价格行为分析。每天上午 8:00 发布。",
  "image": { "@type": "ImageObject", "url": "https://1hcrypto.com/og-default.png", "width": 1200, "height": 630 },
  "datePublished": "2026-06-01T00:00:00+08:00",
  "dateModified": new Date().toISOString(),
  "author": { "@type": "Person", "name": "1H Crypto Trader" },
  "publisher": { "@type": "Organization", "name": "1H币研" }
};
---
<BaseLayout title="每日研判 - BTC & ETH | 1H币研" description="BTC/USDT & ETH/USDT 小时图价格行为分析。" lang="zh" activeNav="daily">
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-8 fade-in-on-scroll">
      <div class="flex items-center gap-2 mb-2"><span class="badge badge-blue">每日研判</span><span class="text-xs text-[var(--text-muted)] font-mono">2026-06-01</span></div>
      <h1 class="text-3xl font-bold text-white mb-2">BTC & ETH 小时图价格行为分析</h1>
      <p class="text-[var(--text-muted)]">Al Brooks 框架 · 每日 8:00 发布 · 含入场/止损/止盈参考</p>
    </div>

    <!-- BTC -->
    <div class="card p-6 mb-6 hover:border-primary/30 transition-colors fade-in-on-scroll border-t-4 border-t-primary">
      <div class="flex items-center gap-2 mb-4"><span class="badge badge-blue">BTC/USDT</span><span class="text-xs text-[var(--text-muted)] font-mono">5 min read</span></div>
      <h2 class="text-xl font-bold text-white mb-3">价格行为分析</h2>
      <p class="text-sm text-[var(--text-secondary)] mb-4">Pin Bar 出现在通道下轨 · 关注 67,200 突破回踩确认 · 多头等待入场信号</p>
      <div class="p-4 bg-[var(--bg-secondary)] rounded-lg mb-4 border-l-3 border-primary">
        <p class="text-xs text-primary font-semibold mb-2">📌 核心摘要</p>
        <p class="text-sm text-[var(--text-primary)] leading-relaxed"><strong>市场结构：</strong>交易区间日。66,800 - 67,800 震荡，无明确趋势。<br><strong>最关键水平：</strong>$67,200 — 区间中轴与前两日 POC。<br><strong>核心判断：</strong>等突破确认或下轨二次测试，不宜追单。</p>
      </div>
      <h3 class="text-white font-semibold mb-2">入场参考</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-4 text-center border border-white/5"><div class="text-xs text-[var(--text-muted)]">入场价</div><div class="text-lg font-bold text-white font-mono">67,200</div></div>
        <div class="bg-red-500/5 rounded-lg p-4 text-center border border-red-500/10"><div class="text-xs text-red-400">止损</div><div class="text-lg font-bold text-red-400 font-mono">66,400</div></div>
        <div class="bg-green-500/5 rounded-lg p-4 text-center border border-green-500/10"><div class="text-xs text-green-400">止盈1</div><div class="text-lg font-bold text-green-400 font-mono">68,500</div></div>
        <div class="bg-green-500/5 rounded-lg p-4 text-center border border-green-500/10"><div class="text-xs text-green-400">止盈2</div><div class="text-lg font-bold text-green-400 font-mono">70,000</div></div>
      </div>
      <h3 class="text-white font-semibold mb-2">关键水平</h3>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-2 mb-4">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">阻力2</div><div class="text-sm font-bold text-white font-mono">68,500</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">阻力1</div><div class="text-sm font-bold text-white font-mono">67,800</div></div>
        <div class="bg-primary/10 rounded-lg p-3 text-center border border-primary/30"><div class="text-xs text-primary">★中枢</div><div class="text-sm font-bold text-primary font-mono">67,200</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">支撑1</div><div class="text-sm font-bold text-white font-mono">66,800</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">支撑2</div><div class="text-sm font-bold text-white font-mono">66,200</div></div>
      </div>
      <h3 class="text-white font-semibold mb-2">链上数据</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-3">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">BTC余额</div><div class="text-sm font-bold text-green-400 font-mono">-3,200</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">持仓量</div><div class="text-sm font-bold text-accent font-mono">+2.1%</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">资金费率</div><div class="text-sm font-bold text-red-400 font-mono">0.03%</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">净流量7d</div><div class="text-sm font-bold text-green-400 font-mono">-1,800</div></div>
      </div>
    </div>

    <!-- ETH -->
    <div class="card p-6 mb-6 hover:border-accent/30 transition-colors fade-in-on-scroll border-t-4 border-t-accent" style="animation-delay:0.1s">
      <div class="flex items-center gap-2 mb-4"><span class="badge badge-amber">ETH/USDT</span><span class="text-xs text-[var(--text-muted)] font-mono">4 min read</span></div>
      <h2 class="text-xl font-bold text-white mb-3">价格行为分析</h2>
      <p class="text-sm text-[var(--text-secondary)] mb-4">双底形态初现 · 关注 3,720 颈线突破 · 成交量放大确认买盘</p>
      <div class="p-4 bg-[var(--bg-secondary)] rounded-lg mb-4 border-l-3 border-accent">
        <p class="text-xs text-accent font-semibold mb-2">📌 核心摘要</p>
        <p class="text-sm text-[var(--text-primary)] leading-relaxed"><strong>市场结构：</strong>双底形成中，3,600附近两次触底，颈线3,680。<br><strong>最关键水平：</strong>$3,720。<br><strong>核心判断：</strong>偏多但需等突破确认，不提前埋伏。</p>
      </div>
      <h3 class="text-white font-semibold mb-2">入场参考</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-4 text-center border border-white/5"><div class="text-xs text-[var(--text-muted)]">入场价</div><div class="text-lg font-bold text-white font-mono">3,725</div></div>
        <div class="bg-red-500/5 rounded-lg p-4 text-center border border-red-500/10"><div class="text-xs text-red-400">止损</div><div class="text-lg font-bold text-red-400 font-mono">3,580</div></div>
        <div class="bg-green-500/5 rounded-lg p-4 text-center border border-green-500/10"><div class="text-xs text-green-400">止盈1</div><div class="text-lg font-bold text-green-400 font-mono">3,850</div></div>
        <div class="bg-green-500/5 rounded-lg p-4 text-center border border-green-500/10"><div class="text-xs text-green-400">止盈2</div><div class="text-lg font-bold text-green-400 font-mono">4,000</div></div>
      </div>
      <h3 class="text-white font-semibold mb-2">关键水平</h3>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-2 mb-4">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">阻力2</div><div class="text-sm font-bold text-white font-mono">3,850</div></div>
        <div class="bg-accent/10 rounded-lg p-3 text-center border border-accent/30"><div class="text-xs text-accent">★颈线</div><div class="text-sm font-bold text-accent font-mono">3,720</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">支撑1</div><div class="text-sm font-bold text-white font-mono">3,600</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">支撑2</div><div class="text-sm font-bold text-white font-mono">3,550</div></div>
      </div>
      <h3 class="text-white font-semibold mb-2">链上数据</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-2 mb-3">
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">ETH余额</div><div class="text-sm font-bold text-green-400 font-mono">-15.2万</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">持仓量</div><div class="text-sm font-bold text-green-400 font-mono">+3.5%</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">资金费率</div><div class="text-sm font-bold text-[var(--text-muted)] font-mono">0.005%</div></div>
      </div>
    </div>

    <!-- 免责 -->
    <div class="mt-8 p-4 bg-[var(--bg-card)]/50 border border-[var(--border)] rounded-lg text-xs text-[var(--text-muted)]">
      <strong class="text-[var(--text-secondary)]">⚠️ 免责声明：</strong>本文仅为个人市场观察，不构成投资建议。模拟盘为虚拟资金。交易有高风险，自行承担决策责任。
    </div>
  </div>
</BaseLayout>
