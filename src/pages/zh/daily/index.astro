        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">持仓量</div><div class="text-sm font-bold font-mono">-1.7%</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">资金费率</div><div class="text-sm font-bold font-mono">-0.07%</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">净流量7d</div><div class="text-sm font-bold font-mono">-2,007</div></div>
      </div>
    </div>

    <!-- ETH -->
