        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">阻力1</div><div class="text-sm font-bold text-white font-mono">1,987</div></div>
        <div class="bg-accent/10 rounded-lg p-3 text-center border border-accent/30"><div class="text-xs text-accent">★颈线</div><div class="text-sm font-bold text-accent font-mono">1,981</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">支撑1</div><div class="text-sm font-bold text-white font-mono">1,954</div></div>
        <div class="bg-[var(--bg-secondary)] rounded-lg p-3 text-center"><div class="text-xs text-[var(--text-muted)]">支撑2</div><div class="text-sm font-bold text-white font-mono">1,975</div></div>
      </div>
      <h3 class="text-white font-semibold mb-2">链上数据</h3>
