                  </p>
                  <p class="text-xs text-[var(--text-muted)] mt-1">ETH</p>
                </div>
              )}
            </div>

            <!-- 多空比 -->
            {ethData.long_short_ratio && ethData.long_short_ratio.length > 0 && (
              <div class="mb-6">
                <h3 class="text-lg font-semibold mb-3">多空账户比</h3>
