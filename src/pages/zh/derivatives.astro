                    {btcData.taker_longshort_ratio[btcData.taker_longshort_ratio.length - 1].buy_sell_ratio > 1 
                      ? '主动买入强势，市场看涨' 
                      : '主动卖出强势，市场看跌'}
                  </p>
                </div>
                <p class="text-xs text-[var(--text-muted)] mt-2">
                  主动买卖量比反映市场即时动能。比值 > 1.2 表示买方积极，{'< 0.8'} 表示卖方主导。
                </p>
              </div>
            )}

            <!-- 情绪信号 -->
            {btcData.sentiment_analysis && btcData.sentiment_analysis.signals && btcData.sentiment_analysis.signals.length > 0 && (
              <div>
                <h3 class="text-lg font-semibold mb-3">情绪信号</h3>
                <div class="space-y-2">
                  {btcData.sentiment_analysis.signals.map((signal) => (
                    <div class="flex items-start gap-2 text-sm bg-[var(--bg-primary)]/50 rounded-lg p-3">
                      <span class="text-yellow-500 mt-0.5 flex-shrink-0">●</span>
                      <span class="text-[var(--text-secondary)]">{signal}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        <!-- ETH 数据 -->
        {ethData && (
          <div class="bg-[var(--bg-card)] border border-[var(--border)] p-6 rounded-2xl">
            <div class="flex items-center justify-between mb-6">
