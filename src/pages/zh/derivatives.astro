                <span class:list={["px-3 py-1 rounded-full text-sm font-medium", sentimentColors[ethData.sentiment_analysis.sentiment] || 'bg-gray-500/20 text-gray-400']}>
                  {sentimentLabels['zh'][ethData.sentiment_analysis.sentiment] || ethData.sentiment_analysis.sentiment}
                </span>
