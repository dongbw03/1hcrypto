<BaseLayout title="衍生品市场情绪 - 1H币研" lang="zh" activeNav="derivatives">
  <div class="min-h-screen bg-[var(--bg-primary)] text-[var(--text-primary)]">
    <section class="py-12 px-4 max-w-6xl mx-auto">
      <!-- 页面标题 -->
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          衍生品市场情绪
        </h1>
        <p class="text-lg text-[var(--text-muted)] max-w-2xl mx-auto">
          基于 Binance Futures 实时数据，追踪资金费率、未平仓合约、多空比、大户持仓、主动买卖量
        </p>
        {derivativesData && (
          <p class="text-sm text-[var(--text-muted)] mt-4">
            数据更新时间: {new Date(derivativesData.timestamp).toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai' })}
          </p>
        )}
      </div>

      {error && (
        <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-6 mb-8">
          <p class="text-red-400">⚠️ 数据加载失败: {error}</p>
          <p class="text-sm text-[var(--text-muted)] mt-2">请确保已运行 python scripts/fetch_derivatives.py</p>
        </div>
      )}

      <!-- 市场总览 -->
