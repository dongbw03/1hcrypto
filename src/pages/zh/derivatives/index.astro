---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<script type="application/ld+json" set:html={`{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "合约交易入门 - 1H币研",
  "description": "加密货币衍生品交易入门：期货合约、永续合约、杠杆交易的核心概念与风险管理",
  "image": {
    "@type": "ImageObject",
    "url": "https://1hcrypto.com/og-default.png",
    "width": 1200,
    "height": 630
  },
  "datePublished": "2026-05-31T20:00:00+08:00",
  "dateModified": "2026-05-31T20:00:00+08:00",
  "author": {
    "@type": "Person",
    "name": "1H Crypto Trader"
  },
  "publisher": {
    "@type": "Organization",
    "name": "1H币研",
    "logo": {
      "@type": "ImageObject",
      "url": "https://1hcrypto.com/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "@id",
    "@id": "https://1hcrypto.com/zh/derivatives/"
  }
}`}></script>
<BaseLayout title="合约交易入门 - 1H币研" lang="zh" activeNav="derivatives" description="加密货币衍生品交易入门：期货合约、永续合约、杠杆交易的核心概念与风险管理">

<div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
  <p class="text-[var(--text-muted)] text-sm mb-2">
    <a href="/zh/" class="text-primary hover:underline">← 返回首页</a>
  </p>

  <h1 class="text-3xl font-bold text-white mb-2">合约交易入门</h1>
  <p class="text-[var(--text-muted)] mb-10 leading-relaxed">加密货币衍生品的核心概念、交易机制与风险管理。新手必读。</p>

  <!-- 实时资金费率 -->
  <section class="mb-12" id="funding-live">
    <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
      <span class="w-1.5 h-6 bg-amber-500 rounded-full inline-block"></span>
      实时资金费率
    </h2>
    <div class="grid md:grid-cols-2 gap-4" id="funding-cards">
      <div class="card p-5 animate-pulse">
        <div class="flex items-center justify-between mb-2">
          <span class="text-white font-semibold">BTC/USDT</span>
          <span class="text-xs text-[var(--text-muted)]">加载中...</span>
        </div>
        <div class="text-2xl font-bold font-mono text-white" id="funding-btc">--</div>
        <div class="text-xs text-[var(--text-muted)] mt-1">下次结算：<span id="funding-time-btc">--</span></div>
      </div>
      <div class="card p-5 animate-pulse">
        <div class="flex items-center justify-between mb-2">
          <span class="text-white font-semibold">ETH/USDT</span>
          <span class="text-xs text-[var(--text-muted)]">加载中...</span>
        </div>
        <div class="text-2xl font-bold font-mono text-white" id="funding-eth">--</div>
        <div class="text-xs text-[var(--text-muted)] mt-1">下次结算：<span id="funding-time-eth">--</span></div>
      </div>
    </div>
    <p class="text-xs text-[var(--text-muted)] mt-3">数据来源：Binance Futures API · 每60秒更新</p>
  </section>

  <!-- 什么是合约交易 -->
  <section class="mb-12">
    <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
      <span class="w-1.5 h-6 bg-primary rounded-full inline-block"></span>
      什么是合约交易？
    </h2>
    <div class="card p-6 space-y-4 text-sm text-[var(--text-muted)] leading-relaxed">
      <p><strong class="text-white">合约交易（Derivatives Trading）</strong>是一种金融衍生品交易，你不需要实际持有加密货币，而是通过<strong class="text-white">预测价格涨跌</strong>来获利。</p>
      <p>与现货交易（买币→持币→卖币）不同，合约交易允许你：</p>
      <ul class="space-y-2 pl-4">
        <li class="flex items-start gap-2"><span class="text-primary mt-0.5">▸</span><strong class="text-white">做多（Long）</strong>：看涨，买入合约，价格上涨获利</li>
        <li class="flex items-start gap-2"><span class="text-primary mt-0.5">▸</span><strong class="text-white">做空（Short）</strong>：看跌，卖出合约，价格下跌获利</li>
        <li class="flex items-start gap-2"><span class="text-primary mt-0.5">▸</span><strong class="text-white">加杠杆（Leverage）</strong>：用少量保证金控制大额仓位，放大收益也放大风险</li>
      </ul>
      <p class="text-amber-300/90">⚠️ 合约交易是高风险行为，可能导致本金的全部损失。新手请先充分了解相关概念，并从小杠杆、小仓位开始。</p>
    </div>
  </section>

  <!-- 关键概念 -->
  <section class="mb-12">
    <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
      <span class="w-1.5 h-6 bg-blue-500 rounded-full inline-block"></span>
      关键概念
    </h2>
    <div class="space-y-4">
      <!-- 杠杆与保证金 -->
      <div class="card p-5">
        <h3 class="text-white font-semibold mb-2">杠杆与保证金</h3>
        <div class="text-sm text-[var(--text-muted)] leading-relaxed space-y-2">
          <p><strong class="text-white">杠杆（Leverage）</strong>：借入资金放大仓位。10x 杠杆意味着你用 $1,000 的保证金可以控制 $10,000 的仓位。</p>
          <p><strong class="text-white">初始保证金（Initial Margin）</strong>：开仓时需要的最低资金。10x 杠杆做多 $10,000 的 BTC，需要 $1,000 初始保证金。</p>
          <p><strong class="text-white">维持保证金（Maintenance Margin）</strong>：维持仓位不被强平的最低资金。如果保证金余额低于此水平，仓位会被强制平仓（Liquidation）。</p>
        </div>
      </div>

      <!-- 强平价格 -->
      <div class="card p-5">
        <h3 class="text-white font-semibold mb-2">强平价格（Liquidation Price）</h3>
        <div class="text-sm text-[var(--text-muted)] leading-relaxed space-y-2">
          <p>当市场价格触及<strong class="text-red-400">强平价格</strong>时，交易所会强制平仓，你的保证金将全部损失。</p>
          <p><strong class="text-white">简化公式（多头）：</strong><code class="bg-white/10 px-1.5 py-0.5 rounded text-xs">强平价格 ≈ 开仓价格 × (1 - 1/杠杆倍数)</code></p>
          <p>例如：$70,000 开多，10x 杠杆，强平价格 ≈ $70,000 × (1 - 0.1) = <strong class="text-red-400">$63,000</strong>。</p>
          <p class="text-amber-300/90">实际强平价格会略高，因为需要预留部分资金作为手续费。务必在开仓前在交易所界面确认准确的强平价格。</p>
        </div>
      </div>

      <!-- 资金费率 -->
      <div class="card p-5">
        <h3 class="text-white font-semibold mb-2">资金费率（Funding Rate）</h3>
        <div class="text-sm text-[var(--text-muted)] leading-relaxed space-y-2">
          <p><strong class="text-white">永续合约（Perpetual Swap）</strong>没有到期日，通过<strong class="text-white">资金费率</strong>机制来锚定现货价格。</p>
          <p><strong class="text-white">资金费率 > 0</strong>：多头支付给空头（市场看涨情绪强）</p>
          <p><strong class="text-white">资金费率 < 0</strong>：空头支付给多头（市场看跌情绪强）</p>
          <p>资金费率通常每 8 小时结算一次（UTC 0:00、8:00、16:00）。持仓过资金费率结算时间，你需要支付或收取资金费。</p>
        </div>
      </div>

      <!-- 标记价格 -->
      <div class="card p-5">
        <h3 class="text-white font-semibold mb-2">标记价格（Mark Price）</h3>
        <div class="text-sm text-[var(--text-muted)] leading-relaxed space-y-2">
          <p>强平不是根据<strong class="text-white">最新成交价</strong>（Last Price）计算的，而是根据<strong class="text-white">标记价格</strong>（Mark Price）。</p>
          <p>标记价格通常是多家交易所现货价格的加权平均值，目的是防止<strong class="text-white">插针（Wick）</strong>导致的非理性强平。</p>
          <p class="text-amber-300/90">⚠️ 即使你的仓位目前是盈利的，如果标记价格触及强平价格，仓位仍会被强平。务必关注标记价格，而非只看最新成交价。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 合约类型 -->
  <section class="mb-12">
    <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
      <span class="w-1.5 h-6 bg-purple-500 rounded-full inline-block"></span>
      合约类型
    </h2>
    <div class="grid md:grid-cols-2 gap-4">
      <div class="card p-5">
        <h3 class="text-white font-semibold mb-2">交割合约（Futures）</h3>
        <div class="text-sm text-[var(--text-muted)] leading-relaxed space-y-1">
          <p>有固定到期日（如每月最后一个周五）。</p>
          <p>到期时按<strong class="text-white">交割价格</strong>结算，合约下架。</p>
          <p class="text-xs text-[var(--text-muted)] mt-2">适合：有明确到期日预期的交易策略。</p>
        </div>
      </div>
      <div class="card p-5">
        <h3 class="text-white font-semibold mb-2">永续合约（Perpetual Swap）</h3>
        <div class="text-sm text-[var(--text-muted)] leading-relaxed space-y-1">
          <p>没有到期日，可以永久持仓。</p>
          <p>通过<strong class="text-white">资金费率</strong>机制锚定现货价格。</p>
          <p class="text-xs text-[var(--text-muted)] mt-2">适合：长期持仓、套利策略。</p>
        </div>
      </div>
      <div class="card p-5">
        <h3 class="text-white font-semibold mb-2">期权（Options）</h3>
        <div class="text-sm text-[var(--text-muted)] leading-relaxed space-y-1">
          <p>购买<strong class="text-white">权利</strong>（非义务）在到期前以约定价格买入/卖出。</p>
          <p>买方风险有限（仅损失权利金），卖方风险较高。</p>
          <p class="text-xs text-[var(--text-muted)] mt-2">适合：复杂策略、对冲、收益增强。</p>
        </div>
      </div>
      <div class="card p-5">
        <h3 class="text-white font-semibold mb-2">合约 vs 现货</h3>
        <div class="text-sm text-[var(--text-muted)] leading-relaxed space-y-1">
          <p><strong class="text-white">现货</strong>：买币→持币→卖币，风险相对可控。</p>
          <p><strong class="text-white">合约</strong>：预测涨跌，可加杠杆，风险极高。</p>
          <p class="text-xs text-[var(--text-muted)] mt-2">新手建议先从现货开始，充分了解市场后再考虑合约。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 风险管理 -->
  <section class="mb-12">
    <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
      <span class="w-1.5 h-6 bg-red-500 rounded-full inline-block"></span>
      风险管理（必读）
    </h2>
    <div class="card p-6 bg-red-500/5 border border-red-500/20">
      <div class="space-y-3 text-sm text-[var(--text-muted)] leading-relaxed">
        <p><strong class="text-red-400">1. 杠杆不是越高越好</strong><br/>高杠杆意味着强平价格更接近开仓价格。新手建议从 2x-5x 开始，熟练后再考虑更高杠杆。</p>
        <p><strong class="text-red-400">2. 必须设置止损（Stop-Loss）</strong><br/>不要心存侥幸。止损是保护本金的最后一道防线。建议止损金额不超过总资金的 1-2%。</p>
        <p><strong class="text-red-400">3. 不要满仓</strong><br/>即使你非常看好，也不要把所有资金用作保证金。留有余地，才能应对市场的波动。</p>
        <p><strong class="text-red-400">4. 警惕"插针"</strong><br/>加密货币市场的流动性不如传统金融市场，短时间内价格可能剧烈波动（插针）。设置止损时，要预留足够的缓冲空间。</p>
        <p><strong class="text-red-400">5. 了解资金费率</strong><br/>持仓过资金费率结算时间，你需要支付资金费。如果资金费率为正且金额较大，长期持仓成本会很高。</p>
      </div>
    </div>
  </section>

  <!-- 推荐交易所 -->
  <section class="mb-12">
    <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
      <span class="w-1.5 h-6 bg-green-500 rounded-full inline-block"></span>
      推荐合约交易平台
    </h2>
    <p class="text-sm text-[var(--text-muted)] mb-6">以下平台均支持合约交易，点击查看详细评测：</p>
    <div class="grid md:grid-cols-3 gap-4">
      <a href="/zh/tools/" class="card p-5 hover:border-primary/30 transition-colors block">
        <h3 class="text-white font-semibold mb-1">Bybit</h3>
        <p class="text-xs text-[var(--text-muted)]">合约交易界面最直观，适合新手</p>
      </a>
      <a href="/zh/tools/" class="card p-5 hover:border-primary/30 transition-colors block">
        <h3 class="text-white font-semibold mb-1">Binance</h3>
        <p class="text-xs text-[var(--text-muted)]">流动性最深，主流交易所</p>
      </a>
      <a href="/zh/tools/" class="card p-5 hover:border-primary/30 transition-colors block">
        <h3 class="text-white font-semibold mb-1">OKX</h3>
        <p class="text-xs text-[var(--text-muted)]">统一账户，资金利用率高</p>
      </a>
    </div>
  </section>

  <div class="mt-8 p-5 bg-amber-600/10 border border-amber-600/20 rounded-lg">
    <h3 class="text-amber-300 font-semibold mb-2">⚠️ 最后提醒</h3>
    <p class="text-sm text-amber-200/80 leading-relaxed">
      合约交易不是"快速致富"的工具。市场上有经验的交易者都在谨慎管理风险，新手更应该如此。
      在充分了解风险、制定交易计划、并设置好止损之前，不要轻易开仓。
    </p>
  </div>
</div>

<!-- 客户端：获取实时资金费率 -->
<script>
  async function fetchFunding() {
    try {
      const res = await fetch('https://fapi.binance.com/fapi/v1/premiumIndex?symbols=%5B%22BTCUSDT%22%2C%22ETHUSDT%22%5D', { signal: AbortSignal.timeout(8000) });
      if (!res.ok) return;
      const data = await res.json();
      data.forEach(d => {
        const rate = parseFloat(d.lastFundingRate) * 100;
        const el = document.getElementById('funding-' + d.symbol.replace('USDT','').toLowerCase());
        const timeEl = document.getElementById('funding-time-' + d.symbol.replace('USDT','').toLowerCase());
        if (el) {
          const cls = rate >= 0 ? 'text-green-400' : 'text-red-400';
          el.className = 'text-2xl font-bold font-mono ' + cls;
          el.textContent = (rate >= 0 ? '+' : '') + rate.toFixed(4) + '%';
        }
        if (timeEl) {
          const next = new Date(d.nextFundingTime);
          timeEl.textContent = next.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit', timeZone: 'UTC' }) + ' UTC';
        }
      });
      // 去掉动画脉冲
      document.querySelectorAll('#funding-cards .animate-pulse').forEach(el => el.classList.remove('animate-pulse'));
    } catch(e) { /* silent */ }
  }
  fetchFunding();
  setInterval(fetchFunding, 60000);
</script>

</BaseLayout>
