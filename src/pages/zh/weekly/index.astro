---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="周度复盘" lang="zh">

<div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
  <h1 class="text-3xl font-bold text-white mb-2">周度复盘</h1>
  <p class="text-[var(--text-muted)] mb-8">每周日发布：本周研判回顾 + 模拟盘表现 + 下周关键结构前瞻。</p>
  <div class="card p-8 text-center">
    <p class="text-sm text-[var(--text-muted)] max-w-md mx-auto">首篇周度复盘将在完成一周每日研判后发布。</p>
  </div>
</div>

</BaseLayout>
