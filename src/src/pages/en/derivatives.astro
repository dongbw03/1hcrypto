---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';

// Read derivatives data at build time
let derivativesData = null;
let error = null;

try {
  const filePath = path.join(process.cwd(), 'src/data/derivatives.json');
  if (fs.existsSync(filePath)) {
    const fileContent = fs.readFileSync(filePath, 'utf-8');
    derivativesData = JSON.parse(fileContent);
  }
} catch (err) {
  error = err.message;
}

// Process data for display
let btcData = null;
let ethData = null;
let hasRealData = false;

if (derivativesData && derivativesData.symbols) {
  btcData = derivativesData.symbols['BTCUSDT'];
  ethData = derivativesData.symbols['ETHUSDT'];
  hasRealData = btcData && (btcData.funding_rate || btcData.open_interest);
}

// Sentiment color mapping
const sentimentColors = {
  'bullish': 'bg-green-500/20 text-green-400 border border-green-500/30',
  'bearish': 'bg-red-500/20 text-red-400 border border-red-500/30',
  'contrarian_bullish': 'bg-yellow-500/20 text-yellow-400 border border-yellow-500/30',
  'contrarian_bearish': 'bg-yellow-500/20 text-yellow-400 border border-yellow-500/30',
  'neutral': 'bg-gray-500/20 text-gray-400 border border-gray-500/30'
};

const sentimentLabels = {
  'en': {
    'bullish': 'Bullish',
    'bearish': 'Bearish',
    'contrarian_bullish': 'Contrarian Bullish',
    'contrarian_bearish': 'Contrarian Bearish',
    'neutral': 'Neutral'
  }
};

const fundingRateColor = (rate) => {
  if (rate > 0.01) return 'text-green-500';
  if (rate < -0.01) return 'text-red-500';
  return 'text-yellow-500';
};

const fundingRateLabel = (rate) => {
  if (rate > 0.01) return 'Longs overheated, watch for pullback';
  if (rate < -0.01) return 'Shorts overcrowded, rebound possible';
  return 'Neutral sentiment';
};
---


