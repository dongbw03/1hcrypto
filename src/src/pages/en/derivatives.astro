                  {btcData.funding_rate[btcData.funding_rate.length - 1].rate > 0 ? '+' : ''}
                  {btcData.funding_rate[btcData.funding_rate.length - 1].rate.toFixed(4)}%
                </p>
                <p class="text-xs text-[var(--text-muted)] mt-1">{fundingRateLabel(btcData.funding_rate[btcData.funding_rate.length - 1].rate)}</p>
              </div>
            )}
            {ethData && ethData.funding_rate && ethData.funding_rate.length > 0 && (
              <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                <p class="text-sm text-[var(--text-muted)] mb-1">ETH Funding Rate</p>
