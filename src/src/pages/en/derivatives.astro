      </div>

      {error && (
        <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-6 mb-8">
          <p class="text-red-400">⚠️ Failed to load data: {error}</p>
          <p class="text-sm text-[var(--text-muted)] mt-2">Please run: python scripts/fetch_derivatives.py</p>
        </div>
      )}

      <!-- Market Overview -->
      {hasRealData && (
        <div class="bg-[var(--bg-card)] border border-[var(--border)] p-6 rounded-2xl mb-8">
