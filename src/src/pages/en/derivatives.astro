  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Derivatives Market Sentiment - 1H Crypto",
  "description": "Real-time Binance Futures derivatives market sentiment analysis: funding rate, open interest, long/short ratio, top trader positions, taker buy/sell ratio",
  "image": {
    "@type": "ImageObject",
    "url": "https://1hcrypto.com/og-default.png",
    "width": 1200,
    "height": 630
  },
  "datePublished": "2026-06-01T16:20:03+08:00",
  "dateModified": "2026-06-01T16:20:03+08:00",
  "author": {
    "@type": "Person",
    "name": "1H Crypto Trader"
  },
  "publisher": {
    "@type": "Organization",
    "name": "1H Crypto",
    "logo": {
      "@type": "ImageObject",
      "url": "https://1hcrypto.com/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "@id",
    "@id": "https://1hcrypto.com/en/derivatives/"
  }
