              <p class="text-lg font-bold text-white">Every 8 hours</p>
              <p class="text-xs text-[var(--text-muted)] mt-1">UTC 00:00 / 08:00 / 16:00</p>
              <p class="text-xs text-[var(--text-muted)]">Beijing 08:00 / 16:00 / 00:00</p>
            </div>
          </div>
        </div>
      )}

      <!-- BTC and ETH Data Cards -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-12">
        <!-- BTC Data -->
