                </p>
                <p class="text-xs text-[var(--text-muted)] mt-1">{fundingRateLabel(ethData.funding_rate[ethData.funding_rate.length - 1].rate)}</p>
              </div>
            )}
            <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
