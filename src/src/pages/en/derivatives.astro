                    <span class="text-green-500 font-bold">
                      {(btcData.top_trader_ls_ratio[btcData.top_trader_ls_ratio.length - 1].long_ratio * 100).toFixed(1)}%
                    </span>
                  </div>
                  <div class="w-full bg-[var(--bg-primary)]/30 rounded-full h-3 mb-2">
                    <div 
                      class="bg-blue-500 h-3 rounded-full transition-all" 
                      style={`width: ${btcData.top_trader_ls_ratio[btcData.top_trader_ls_ratio.length - 1].long_ratio * 100}%`}
                    ></div>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-[var(--text-muted)]">Top Trader Short</span>
                    <span class="text-red-500 font-bold">
                      {(btcData.top_trader_ls_ratio[btcData.top_trader_ls_ratio.length - 1].short_ratio * 100).toFixed(1)}%
                    </span>
                  </div>
                </div>
                <p class="text-xs text-[var(--text-muted)] mt-2">
                  Top trader positioning is often viewed as "smart money" guidance. Divergence from retail sentiment may signal reversal opportunities.
                </p>
              </div>
            )}

            <!-- Taker Buy/Sell Ratio -->
            {btcData.taker_longshort_ratio && btcData.taker_longshort_ratio.length > 0 && (
              <div class="mb-6">
                <h3 class="text-lg font-semibold mb-3">Taker Buy/Sell Ratio</h3>
                <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-[var(--text-muted)]">Taker Buy / Taker Sell</span>
                    <span class="text-yellow-500 font-bold">
                      {btcData.taker_longshort_ratio[btcData.taker_longshort_ratio.length - 1].buy_sell_ratio.toFixed(2)}
                    </span>
                  </div>
                  <p class="text-xs text-[var(--text-muted)] mt-1">
                    {btcData.taker_longshort_ratio[btcData.taker_longshort_ratio.length - 1].buy_sell_ratio > 1 
                      ? 'More buying pressure from takers' 
                      : 'More selling pressure from takers'}
                  </p>
                </div>
                <p class="text-xs text-[var(--text-muted)] mt-2">
                  Ratio &gt; 1.2 indicates aggressive buying; &lt; 0.8 suggests selling dominance.
                </p>
              </div>
            )}

            <!-- Sentiment Signals -->
            {btcData.sentiment_analysis && btcData.sentiment_analysis.signals && btcData.sentiment_analysis.signals.length > 0 && (
              <div>
                <h3 class="text-lg font-semibold mb-3">Sentiment Signals</h3>
                <div class="space-y-2">
                  {btcData.sentiment_analysis.signals.map((signal) => (
                    <div class="flex items-start gap-2 text-sm bg-[var(--bg-primary)]/50 rounded-lg p-3">
                      <span class="text-yellow-500 mt-0.5 flex-shrink-0">●</span>
                      <span class="text-[var(--text-secondary)]">{signal}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        <!-- ETH Data -->
        {ethData && (
          <div class="bg-[var(--bg-card)] border border-[var(--border)] p-6 rounded-2xl">
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center text-blue-500 text-xl font-bold">Ξ</div>
                <div>
                  <h2 class="text-2xl font-bold">ETH</h2>
                  <p class="text-sm text-[var(--text-muted)]">ETH/USDT Perpetual</p>
                </div>
              </div>
              {ethData.sentiment_analysis && (
                <span class:list={["px-3 py-1 rounded-full text-sm font-medium", sentimentColors[ethData.sentiment_analysis.sentiment] || 'bg-gray-500/20 text-gray-400']}>
                  {sentimentLabels['en'][ethData.sentiment_analysis.sentiment] || ethData.sentiment_analysis.sentiment}
                </span>
              )}
            </div>

            <div class="grid grid-cols-2 gap-4 mb-6">
              <!-- Funding Rate -->
              {ethData.funding_rate && ethData.funding_rate.length > 0 && (
                <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                  <p class="text-sm text-[var(--text-muted)] mb-1">Funding Rate</p>
                  <p class:list={["text-2xl font-bold", ethData.funding_rate[ethData.funding_rate.length - 1].rate > 0 ? 'text-green-500' : 'text-red-500']}>
                    {ethData.funding_rate[ethData.funding_rate.length - 1].rate > 0 ? '+' : ''}
                    {ethData.funding_rate[ethData.funding_rate.length - 1].rate.toFixed(4)}%
                  </p>
                  <p class="text-xs text-[var(--text-muted)] mt-1">Latest</p>
                </div>
              )}

              <!-- Open Interest -->
              {ethData.open_interest && (
                <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                  <p class="text-sm text-[var(--text-muted)] mb-1">Open Interest</p>
                  <p class="text-2xl font-bold">
                    {new Intl.NumberFormat('en-US', { maximumFractionDigits: 0, notation: 'compact' }).format(ethData.open_interest.open_interest)}
                  </p>
                  <p class="text-xs text-[var(--text-muted)] mt-1">ETH</p>
                </div>
              )}
            </div>

            <!-- Long/Short Ratio -->
            {ethData.long_short_ratio && ethData.long_short_ratio.length > 0 && (
              <div class="mb-6">
                <h3 class="text-lg font-semibold mb-3">Long/Short Account Ratio</h3>
                <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-sm text-[var(--text-muted)]">Long</span>
                    <span class="text-green-500 font-bold">
                      {(ethData.long_short_ratio[ethData.long_short_ratio.length - 1].long_ratio * 100).toFixed(1)}%
                    </span>
                  </div>
                  <div class="w-full bg-[var(--bg-primary)]/30 rounded-full h-3 mb-2">
                    <div 
                      class="bg-green-500 h-3 rounded-full transition-all" 
                      style={`width: ${ethData.long_short_ratio[ethData.long_short_ratio.length - 1].long_ratio * 100}%`}
                    ></div>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-[var(--text-muted)]">Short</span>
                    <span class="text-red-500 font-bold">
                      {(ethData.long_short_ratio[ethData.long_short_ratio.length - 1].short_ratio * 100).toFixed(1)}%
                    </span>
                  </div>
                </div>
              </div>
            )}

            <!-- Top Trader Ratio -->
            {ethData.top_trader_ls_ratio && ethData.top_trader_ls_ratio.length > 0 && (
