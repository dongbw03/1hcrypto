            {btcData && btcData.funding_rate && btcData.funding_rate.length > 0 && (
              <div class="bg-[var(--bg-primary)]/50 rounded-xl p-4">
                <p class="text-sm text-[var(--text-muted)] mb-1">BTC Funding Rate</p>
