<BaseLayout title="Derivatives Market Sentiment - 1H Crypto" lang="en" activeNav="derivatives">
  <div class="min-h-screen bg-[var(--bg-primary)] text-[var(--text-primary)]">
    <section class="py-12 px-4 max-w-6xl mx-auto">
      <!-- Page Header -->
