---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const analysisFiles = await import.meta.glob("../../../content/zh/analysis/*.md", { eager: true });
  const paths = Object.entries(analysisFiles).map(([filePath, module]) => {
    const filename = filePath.split("/").pop().replace(".md", "");
    const slug = filename.replace(/^\d{4}-\d{2}-\d{2}-\d{2}-\d{2}-/, "");
    return {
      params: { slug },
      props: { module },
    };
  });
  return paths;
}

const { module } = Astro.props;
const data = module.frontmatter || {};
const content = module.compiledContent ? module.compiledContent() : "";
const headings = module.getHeadings ? module.getHeadings() : [];

const title = data.title || "无标题";
const date = data.date || new Date().toISOString();
const tags = data.tags || [];
const market = data.market || "";
const signal = data.signal || "中性";
const description = data.description || content.replace(/<[^>]+>/g, "").substring(0, 160);
const fmtDate = new Date(date).toLocaleDateString('zh-CN', { year:'numeric', month:'long', day:'numeric' });
const signalColor = signal === "看多" ? "text-green-400 bg-green-500/10 border-green-500/40" : signal === "看空" ? "text-red-400 bg-red-500/10 border-red-500/40" : "text-yellow-400 bg-yellow-500/10 border-yellow-500/40";
const signalDot = signal === "看多" ? "bg-green-400" : signal === "看空" ? "bg-red-400" : "bg-yellow-400";
const wordCount = content.replace(/<[^>]+>/g, "").length;
const readTime = Math.max(1, Math.ceil(wordCount / 500));
---
<script type="application/ld+json" set:html={`{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "${title.replace(/"/g, '\\"')}",
  "datePublished": "${date}",
  "description": "${description.replace(/"/g, '\\"')}",
  "inLanguage": "zh"
}`}></script>

<BaseLayout title={title} description={description} lang="zh">
  <!-- 阅读进度条 -->
  <div id="reading-progress" class="fixed top-0 left-0 w-0 h-0.5 bg-gradient-to-r from-blue-500 via-cyan-400 to-blue-400 z-50 transition-all duration-150 ease-out shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>

  <div class="max-w-[1600px] mx-auto lg:pl-12 lg:pr-1 px-4 py-8 lg:py-12">
    <!-- 顶部导航 -->
    <div class="mb-8">
      <a href="/zh/analysis" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-blue-400 transition-colors group">
        <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        返回所有分析
      </a>
    </div>

    <div class="lg:flex lg:gap-12 xl:gap-16">
      <!-- 主内容区 -->
      <article class="flex-1 min-w-0">
        <!-- 文章头部 -->
        <header class="mb-12">
          <!-- 标签行 -->
          <div class="flex flex-wrap items-center gap-2 mb-6">
            {tags.map((tag) => (
              <span class="text-xs px-3 py-1 rounded-full bg-blue-500/10 text-blue-400 border border-blue-500/20 hover:bg-blue-500/20 transition-colors cursor-default">{tag}</span>
            ))}
            {market && <span class="text-xs px-3 py-1 rounded-full bg-purple-500/10 text-purple-400 border border-purple-500/20">{market}</span>}
            <span class={`text-xs px-3 py-1 rounded-full border flex items-center gap-1.5 ${signalColor}`}>
              <span class={`inline-block w-1.5 h-1.5 rounded-full animate-pulse ${signalDot}`}></span>
              {signal}
            </span>
          </div>

          <!-- 标题 -->
          <h1 class="text-xl md:text-2xl lg:text-[1.65rem] font-bold text-white leading-[1.35] mb-5 tracking-tight">
            <span class="bg-gradient-to-r from-white via-white to-gray-300 bg-clip-text">{title}</span>
          </h1>

          <!-- 元信息 -->
          <div class="flex flex-wrap items-center gap-5 text-sm text-gray-400">
            <time datetime={date} class="flex items-center gap-2">
              <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              {fmtDate}
            </time>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              约 {readTime} 分钟阅读
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.413.585l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 9.172V4a2 2 0 012-2z"/></svg>
              价格分析
            </span>
          </div>
        </header>

        <!-- 分隔线 -->
        <div class="mb-12 flex items-center gap-4">
          <div class="flex-1 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
          <div class="w-2 h-2 rounded-full bg-blue-500/60"></div>
          <div class="flex-1 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
        </div>

        <!-- 文章正文 -->
        <div class="article-content w-full" set:html={content} />

        <!-- 文章底部 -->
        <div class="mt-20 pt-10 border-t border-white/10">
          <div class="flex flex-wrap items-center gap-3">
            <span class="text-sm text-gray-500 mr-1">标签：</span>
            {tags.map((tag) => (
              <span class="text-xs px-3 py-1 rounded-full bg-white/5 text-gray-300 border border-white/10 hover:border-blue-500/30 hover:text-blue-400 transition-colors cursor-default">{tag}</span>
            ))}
          </div>

          <!-- 底部分隔装饰 -->
          <div class="mt-12 flex items-center gap-3">
            <div class="flex-1 h-px bg-gradient-to-r from-blue-500/50 to-transparent"></div>
            <span class="text-xs text-gray-600">END</span>
            <div class="flex-1 h-px bg-gradient-to-r from-transparent to-blue-500/50"></div>
          </div>
        </div>
      </article>

      <!-- 右侧目录 (桌面端) -->
      {headings.length > 0 && (
        <aside class="hidden lg:block w-48 flex-shrink-0">
          <div class="sticky top-24">
            <nav id="toc-desktop" class="bg-[#0d1117] border border-white/10 rounded-2xl p-5">
              <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-4 flex items-center gap-2">
                <svg class="w-3.5 h-3.5 text-blue-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                目录
              </h3>
              <ul class="space-y-0.5 list-none p-0 m-0">
                {headings
                  .filter(h => h.depth === 2 || h.depth === 3)
                  .map((h, i) => (
                    <li class={h.depth === 3 ? "ml-4" : ""}>
                      <a
                        href={`#${h.slug}`}
                        data-heading={h.slug}
                        class:list={[
                          "toc-link block text-sm py-1.5 px-3 rounded-lg transition-all duration-200 no-underline",
                          "text-gray-400 hover:text-white hover:bg-white/5",
                          h.depth === 3 ? "text-xs" : "text-sm font-medium",
                          "border-l-2 border-transparent hover:border-blue-500/60"
                        ]}
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}
    </div>

    <!-- 移动端目录 -->
    {headings.length > 0 && (
      <details class="lg:hidden mt-10 bg-[#0d1117] border border-white/10 rounded-2xl overflow-hidden">
        <summary class="cursor-pointer select-none px-5 py-3.5 text-sm font-semibold text-gray-300 flex items-center justify-between hover:bg-white/[0.03] transition-colors">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
            目录
          </span>
          <svg class="w-4 h-4 text-gray-500 transition-transform details-arrow" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <nav class="px-5 pb-4">
          <ul class="space-y-0.5 list-none p-0 m-0">
            {headings
              .filter(h => h.depth === 2 || h.depth === 3)
              .map((h) => (
                <li class={h.depth === 3 ? "ml-4" : ""}>
                  <a href={`#${h.slug}`} class="toc-link block text-sm py-1.5 px-3 rounded-lg transition-colors no-underline text-gray-400 hover:text-white">{h.text}</a>
                </li>
              ))}
          </ul>
        </nav>
      </details>
    )}
  </div>

  <!-- 回到顶部按钮 -->
  <button id="back-to-top" class="fixed bottom-8 right-8 w-10 h-10 rounded-full bg-blue-500/90 text-white shadow-lg shadow-blue-500/30 flex items-center justify-center opacity-0 translate-y-4 pointer-events-none transition-all duration-300 hover:bg-blue-600 z-40" aria-label="回到顶部">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
  </button>

  <!-- 文章排版样式 (不依赖 prose 类) -->
  <style is:global>
    .article-content {
      color: #c9cdd4;
      font-size: 1.05rem;
      line-height: 1.9;
      max-width: none;
      font-variant-numeric: tabular-nums;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* 标题样式 */
    .article-content h1 {
      font-size: 1.75rem;
      font-weight: 800;
      color: #f0f0f0;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      letter-spacing: -0.025em;
    }
    .article-content h2 {
      font-size: 1.4rem;
      font-weight: 700;
      color: #e8e8e8;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      padding-left: 1rem;
      border-left: 3px solid #4b9cf5;
      line-height: 1.45;
    }
    .article-content h3 {
      font-size: 1.15rem;
      font-weight: 600;
      color: #d8d8d8;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .article-content h3::before {
      content: '';
      display: inline-block;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: #4b9cf5;
      flex-shrink: 0;
    }
    .article-content h4 {
      font-size: 1.02rem;
      font-weight: 600;
      color: #b8bcc4;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
    }

    /* 段落 */
    .article-content p {
      margin-bottom: 1.4rem;
      color: #c9cdd4;
    }

    /* 链接 */
    .article-content a {
      color: #6baff7;
      text-decoration: underline;
      text-decoration-color: rgba(107, 175, 247, 0.3);
      text-underline-offset: 4px;
      text-decoration-thickness: 1px;
      transition: all 0.2s;
    }
    .article-content a:hover {
      color: #9ecffb;
      text-decoration-color: rgba(107, 175, 247, 0.7);
      text-decoration-thickness: 2px;
    }

    /* 加粗 */
    .article-content strong {
      color: #ececec;
      font-weight: 600;
    }

    /* 行内代码 */
    .article-content code {
      color: #8ec8fd;
      background: rgba(59, 130, 246, 0.08);
      padding: 0.18em 0.45em;
      border-radius: 0.375rem;
      font-size: 0.88em;
      font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', 'Cascadia Code', monospace;
      border: 1px solid rgba(59, 130, 246, 0.12);
    }

    /* 代码块 */
    .article-content pre {
      background: #0d1117 !important;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 0.75rem;
      padding: 1.25rem 1.5rem;
      overflow-x: auto;
      margin: 1.5rem 0;
      position: relative;
      font-size: 0.88rem;
      line-height: 1.75;
    }
    .article-content pre code {
      background: none;
      padding: 0;
      border: none;
      color: #c9d1d9;
      font-size: inherit;
    }

    /* 引用块 */
    .article-content blockquote {
      border-left: 3px solid #4b9cf5;
      background: rgba(59, 130, 246, 0.04);
      margin: 1.5rem 0;
      padding: 1rem 1.5rem;
      border-radius: 0 0.5rem 0.5rem 0;
      color: #8b949e;
    }
    .article-content blockquote p {
      margin-bottom: 0.5rem;
    }
    .article-content blockquote p:last-child {
      margin-bottom: 0;
    }

    /* 列表 */
    .article-content ul, .article-content ol {
      padding-left: 1.5rem;
      margin: 1rem 0;
    }
    .article-content li {
      color: #c9cdd4;
      margin-bottom: 0.55rem;
      line-height: 1.8;
    }
    .article-content ul li::marker {
      color: #4b9cf5;
    }
    .article-content ol li::marker {
      color: #4b9cf5;
      font-weight: 600;
    }

    /* 表格 */
    .article-content table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
      font-size: 0.93rem;
      border-radius: 0.75rem;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.07);
    }
    .article-content th {
      background: rgba(255,255,255,0.04);
      padding: 0.7rem 1rem;
      text-align: left;
      font-size: 0.83rem;
      font-weight: 600;
      color: #d0d0d0;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .article-content td {
      padding: 0.65rem 1rem;
      font-size: 0.88rem;
      color: #8b949e;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .article-content tr:last-child td {
      border-bottom: none;
    }
    .article-content tr:hover td {
      background: rgba(255,255,255,0.025);
    }

    /* 图片 */
    .article-content img {
      border-radius: 0.75rem;
      border: 1px solid rgba(255,255,255,0.08);
      margin: 1.5rem 0;
      max-width: 100%;
    }

    /* 水平分割线 */
    .article-content hr {
      border: none;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(255,255,255,0.12), transparent);
      margin: 2.5rem 0;
    }

    /* 标题锚点 */
    .article-content h1, .article-content h2, .article-content h3, .article-content h4 {
      scroll-margin-top: 100px;
    }
  </style>

  <!-- 交互脚本 -->
  <script>
    // 阅读进度条
    const progressBar = document.getElementById('reading-progress');
    const article = document.querySelector('.article-content');
    function updateProgress() {
      if (!article || !progressBar) return;
      const rect = article.getBoundingClientRect();
      const articleTop = article.offsetTop;
      const articleHeight = article.offsetHeight;
      const scrolled = window.scrollY - articleTop + window.innerHeight * 0.5;
      const pct = Math.min(100, Math.max(0, (scrolled / articleHeight) * 100));
      progressBar.style.width = pct + '%';
    }
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();

    // 回到顶部按钮
    const backBtn = document.getElementById('back-to-top');
    window.addEventListener('scroll', () => {
      if (!backBtn) return;
      if (window.scrollY > 400) {
        backBtn.style.opacity = '1';
        backBtn.style.transform = 'translateY(0)';
        backBtn.style.pointerEvents = 'auto';
      } else {
        backBtn.style.opacity = '0';
        backBtn.style.transform = 'translateY(16px)';
        backBtn.style.pointerEvents = 'none';
      }
    }, { passive: true });
    backBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

    // TOC 滚动高亮 (scroll spy)
    const tocLinks = document.querySelectorAll('.toc-link');
    if (tocLinks.length > 0) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const id = entry.target.id;
          const link = document.querySelector(`.toc-link[data-heading="${id}"]`);
          if (!link) return;
          if (entry.isIntersecting) {
            tocLinks.forEach(l => { l.classList.remove('!text-white', '!border-blue-500', 'bg-white/5'); });
            link.classList.add('!text-white', '!border-blue-500', 'bg-white/5');
          }
        });
      }, { rootMargin: '-80px 0px -70% 0px' });

      document.querySelectorAll('h2, h3').forEach(h => {
        if (h.id) observer.observe(h);
      });
    }

    // 移动端目录箭头动画
    document.querySelectorAll('details').forEach(details => {
      const arrow = details.querySelector('.details-arrow');
      if (!arrow) return;
      details.addEventListener('toggle', () => {
        arrow.style.transform = details.open ? 'rotate(180deg)' : 'rotate(0deg)';
      });
    });
  </script>
</BaseLayout>
