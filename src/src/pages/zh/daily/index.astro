---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import matter from 'gray-matter';

const dailyFiles = await import.meta.glob('../../../content/zh/daily/*.md', { eager: true });
const posts = Object.entries(dailyFiles)
  .map(([filePath, module]) => {
    const raw = module.rawContent();
    const { data } = matter(raw);
    const fileName = filePath.split('/').pop().replace(/\.md$/, '');
    return { date: data.date || fileName, title: data.title, description: data.description, sentiment: data.sentiment, fileName };
  })
  .sort((a, b) => b.date.localeCompare(a.date));
---

<BaseLayout title="每日研判 - BTC & ETH | 1H币研" description="BTC/USDT & ETH/USDT 小时图价格行为分析，每天上午 8:00 发布。" lang="zh" activeNav="daily">
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "每日研判 - BTC & ETH 小时图价格行为分析",
    "description": "BTC/USDT & ETH/USDT 小时图价格行为分析。每天上午 8:00 发布。",
    "datePublished": "{posts[0]?.date}T00:00:00+08:00",
    "author": {"@type": "Person", "name": "1H Crypto Trader"},
    "publisher": {"@type": "Organization", "name": "1H币研"}
  }</script>

  <div class="max-w-[1400px] mx-auto lg:pl-10 lg:pr-2 px-4 py-8 lg:py-12">
    <div class="mb-12 max-w-[1080px]">
      <div class="flex items-center gap-2 mb-2"><span class="badge badge-blue">每日研判</span><span class="text-xs text-[var(--text-muted)] font-mono">每日 8:00 更新</span></div>
      <h1 class="text-xl md:text-2xl lg:text-[1.65rem] font-bold text-white leading-[1.35] mb-5 tracking-tight">BTC & ETH 小时图价格行为分析</h1>
      <p class="text-[var(--text-muted)]">Al Brooks 框架 · 含入场/止损/止盈参考 · 每日早上 8:00 发布</p>
    </div>

    <div class="grid gap-6">
      {posts.map((post, i) => (
        <a href={`/zh/daily/${post.fileName}/`} class="card p-6 hover:border-primary/30 transition-colors fade-in-on-scroll block" style={`animation-delay:${i * 0.08}s`}>
          <div class="flex items-center gap-2 mb-3">
            <span class:list={["badge", `badge-${post.sentiment === '偏多' ? 'green' : post.sentiment === '偏空' ? 'red' : 'blue'}`]}>{post.sentiment}</span>
            <span class="text-xs text-[var(--text-muted)] font-mono">{post.date}</span>
            <span class="text-xs text-[var(--text-muted)] ml-auto">1H</span>
          </div>
          <h2 class="text-xl font-bold text-white mb-2">{post.title}</h2>
          <p class="text-sm text-[var(--text-secondary)] line-clamp-2">{post.description}</p>
          <div class="flex items-center gap-4 mt-4 text-xs text-[var(--text-muted)]">
            <span>📊 市场结构</span>
            <span>📌 核心判断</span>
            <span>📈 入场参考</span>
            <span class="ml-auto hover:text-primary transition-colors">阅读全文 →</span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-8 pt-6 border-t border-[var(--border)] flex flex-wrap gap-4 text-sm">
      <a href="/zh/analysis/" class="text-primary hover:underline no-underline">📈 价格分析</a>
      <a href="/zh/trading/" class="text-primary hover:underline no-underline">📊 模拟盘</a>
      <a href="/zh/learn/" class="text-primary hover:underline no-underline">📚 学习中心</a>
    </div>
  </div>
</BaseLayout>
