---
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const newsFiles = await import.meta.glob("../../../content/zh/news/*.md", { eager: true });
  const paths = Object.entries(newsFiles).map(([filePath, module]) => {
    const slug = filePath.split("/").pop().replace(".md", "");
    return {
      params: { slug },
      props: { module },
    };
  });
  return paths;
}

const { module } = Astro.props;
const data = module.frontmatter || {};
const content = module.compiledContent ? module.compiledContent() : "";

const title = data.title || "无标题";
const date = data.date || new Date().toISOString();
const sentiment = data.sentiment || "中性";
const coins = data.coins || [];
const importance = data.importance || "低";
const fmtDate = new Date(date).toLocaleDateString('zh-CN', { year:'numeric', month:'long', day:'numeric' });
const sentimentColor = sentiment === "看涨" ? "text-green-400 bg-green-500/10 border-green-500/30" : sentiment === "看跌" ? "text-red-400 bg-red-500/10 border-red-500/30" : "text-yellow-400 bg-yellow-500/10 border-yellow-500/30";
const importanceBorder = importance === "高" ? "border-l-red-500" : importance === "中" ? "border-l-yellow-500" : "border-l-green-500";
---
<script type="application/ld+json" set:html={`{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "${title.replace(/"/g, '\\"')} | 1H币研",
  "description": "加密市场新闻快报，含AI摘要与多空判断。",
  "datePublished": "${new Date(date).toISOString()}",
  "dateModified": "${new Date(date).toISOString()}",
  "author": { "@type": "Person", "name": "1H币研" },
  "publisher": { "@type": "Organization", "name": "1H币研", "logo": { "@type": "ImageObject", "url": "https://1hcrypto.com/favicon.svg" } },
  "mainEntityOfPage": { "@type": "@id", "@id": "https://1hcrypto.com/zh/news/${Astro.params.slug}/" }
}`}></script>

<BaseLayout 
  title={`${title} | 新闻快报 | 1H币研`}
  description={`${title} — AI摘要与多空判断。`}
  lang="zh"
  activeNav="news"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <!-- Back -->
    <a href="/zh/news/" class="inline-flex items-center gap-1 text-sm text-[var(--text-muted)] hover:text-primary transition-colors no-underline mb-6">
      ← 返回新闻快报
    </a>

    <!-- Article Header -->
    <div class={`card p-6 mb-6 border-l-4 ${importanceBorder}`}>
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class={`text-xs font-bold px-2 py-0.5 rounded ${sentimentColor}`}>{sentiment}</span>
        <span class="text-[var(--text-muted)] text-xs">{fmtDate}</span>
        {importance === "高" && <span class="badge badge-red">重要</span>}
      </div>
      <h1 class="text-2xl font-bold text-white mb-3 leading-tight">{title}</h1>
      {coins && coins.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {coins.map(coin => (
            <span class="text-xs px-2 py-0.5 rounded bg-[var(--bg-card)] text-primary font-mono border border-[var(--border)]">{coin}</span>
          ))}
        </div>
      )}
    </div>

    <!-- Article Body -->
    <div class="card p-6 md:p-8">
      <article class="prose prose-invert prose-sm max-w-none
        prose-p:text-[var(--text-secondary)] prose-p:leading-relaxed prose-p:mb-4
        prose-h2:text-white prose-h2:text-lg prose-h2:font-bold prose-h2:mt-6 prose-h2:mb-3 prose-h2:pb-2 prose-h2:border-b prose-h2:border-[var(--border)]
        prose-h3:text-white prose-h3:text-base prose-h3:font-semibold prose-h3:mt-4 prose-h3:mb-2
        prose-strong:text-white
        prose-blockquote:border-l-primary prose-blockquote:bg-[var(--primary)]/5 prose-blockquote:rounded-r-lg prose-blockquote:py-3 prose-blockquote:px-4 prose-blockquote:my-4 prose-blockquote:text-[var(--text-secondary)]
        prose-code:text-primary prose-code:bg-[var(--bg-card)] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-xs
        prose-ul:pl-5 prose-li:text-[var(--text-secondary)] prose-li:mb-1
        prose-ol:pl-5
      ">
        <Fragment set:html={content} />
      </article>
    </div>

    <!-- 多空判断（文末强调） -->
    <div class={`mt-6 card p-4 border-l-4 ${importanceBorder} bg-[var(--bg-card)]/50`}>
      <div class="flex items-center gap-2 mb-1">
        <span class={`text-sm font-bold ${sentiment === "看涨" ? "text-green-400" : sentiment === "看跌" ? "text-red-400" : "text-yellow-400"}`}>
          {sentiment === "看涨" ? "📈 偏多判断" : sentiment === "看跌" ? "📉 偏空判断" : "⚖️ 中性判断"}
        </span>
      </div>
      <p class="text-xs text-[var(--text-muted)] mt-1">以上判断基于公开信息分析，仅供参考，不构成投资建议。</p>
    </div>

    <!-- Disclaimer -->
    <div class="mt-8 p-4 bg-[var(--bg-card)]/50 border border-[var(--border)] rounded-lg text-xs text-[var(--text-muted)]">
      <strong class="text-[var(--text-secondary)]">⚠️ 免责声明：</strong>本文内容由 AI 基于公开资讯自动生成并改写，仅供学习参考，不构成任何投资建议。投资有风险，入市需谨慎。
    </div>
  </div>
</BaseLayout>
